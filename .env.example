# Neon pooled URL (preferred name for Drizzle / app code)
DATABASE_URL=

# Legacy name still supported in code and drizzle.config if DATABASE_URL is unset
# NEON_DATABASE_CONNECTION_STRING=

# Financial Modeling Prep (server-only; see docs/ACTION_PLAN.md)
FMP_API_KEY=

# Vercel Cron + local tests: send `Authorization: Bearer <secret>` to /api/cron/*
CRON_SECRET=

# Resend (subscribe double opt-in — server only)
RESEND_API_KEY=
# Optional verified sender, e.g. Yield to Freedom <hello@yieldtofreedom.com>
# Falls back to Resend onboarding sender for local dev.
RESEND_FROM=

# Confirmation links in emails — no trailing slash. Local default: http://localhost:4321
PUBLIC_SITE_URL=

# Optional Google Analytics 4 — injected in Base layout when set (e.g. G-XXXXXXXXXX)
PUBLIC_GA_MEASUREMENT_ID=
