---
import Base from '../layouts/Base.astro';
---

<Base
  title="Contact | Yield to Freedom"
  description="Questions about ETF data, missing funds, or anything else — get in touch with the Yield to Freedom team."
>
  <div class="mx-auto max-w-xl">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900">Get in touch</h1>
    <p class="mt-3 text-slate-600">
      Spotted a data issue, want to suggest an ETF we should cover, or just have a question?
      Drop us a note and we'll get back to you.
    </p>

    <form
      id="contact-form"
      class="mt-8 space-y-5"
      novalidate
    >
      <!-- Web3Forms access key -->
      <input type="hidden" name="access_key" value="3fc41ed7-9fe7-4316-9b20-4a5406f2a419" />
      <input type="hidden" name="subject" value="Yield to Freedom contact form" />
      <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

      <div>
        <label for="cf-name" class="block text-sm font-semibold text-slate-700">Name</label>
        <input
          id="cf-name"
          name="name"
          type="text"
          required
          autocomplete="name"
          placeholder="Your name"
          class="mt-1.5 block w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20"
        />
      </div>

      <div>
        <label for="cf-email" class="block text-sm font-semibold text-slate-700">Email</label>
        <input
          id="cf-email"
          name="email"
          type="email"
          required
          autocomplete="email"
          placeholder="you@example.com"
          class="mt-1.5 block w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20"
        />
      </div>

      <div>
        <label for="cf-message" class="block text-sm font-semibold text-slate-700">Message</label>
        <textarea
          id="cf-message"
          name="message"
          required
          rows="5"
          placeholder="What's on your mind?"
          class="mt-1.5 block w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20"
        ></textarea>
      </div>

      <div id="cf-error" class="hidden rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700"></div>

      <button
        type="submit"
        id="cf-submit"
        class="w-full rounded-xl bg-blue-800 px-6 py-3 text-sm font-bold text-white shadow-sm transition hover:bg-blue-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-60"
      >
        Send message
      </button>
    </form>

    <!-- Success state (hidden until submit) -->
    <div id="cf-success" class="hidden mt-8 rounded-2xl border border-emerald-200 bg-emerald-50 px-6 py-8 text-center">
      <p class="text-2xl">✓</p>
      <p class="mt-2 font-semibold text-emerald-900">Message sent!</p>
      <p class="mt-1 text-sm text-emerald-700">We'll get back to you at the email you provided.</p>
    </div>
  </div>
</Base>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('cf-submit') as HTMLButtonElement | null;
  const successEl = document.getElementById('cf-success');
  const errorEl = document.getElementById('cf-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !submitBtn) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';
    if (errorEl) errorEl.classList.add('hidden');

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(Object.fromEntries(new FormData(form))),
      });
      const data = await res.json() as { success: boolean; message?: string };

      if (data.success) {
        form.classList.add('hidden');
        successEl?.classList.remove('hidden');
      } else {
        throw new Error(data.message ?? 'Submission failed');
      }
    } catch (err) {
      if (errorEl) {
        errorEl.textContent = err instanceof Error ? err.message : 'Something went wrong. Please try again.';
        errorEl.classList.remove('hidden');
      }
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send message';
    }
  });
</script>
