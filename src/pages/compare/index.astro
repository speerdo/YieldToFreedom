---
import { asc, eq } from 'drizzle-orm';

import Base from '../../layouts/Base.astro';
import Disclaimer from '../../components/ui/Disclaimer.astro';
import { db } from '../../lib/db';
import { etfs } from '../../lib/db/schema';

const catalog = await db
  .select({
    ticker: etfs.ticker,
    name: etfs.name,
    pillar: etfs.pillar,
    category: etfs.category,
  })
  .from(etfs)
  .where(eq(etfs.isActive, true))
  .orderBy(asc(etfs.ticker));

const catalogJson = JSON.stringify(catalog);
const CANVAS_ID = 'ytf-compare-yield-chart';
---

<Base
  title="Compare income ETFs - Yield to Freedom"
  description="Pick up to three ETFs by ticker and contrast trailing dividend yield curves, Yield to Freedom grades, and payout metrics side by side - not advice."
>
  <article>
    <h1 class="text-3xl font-bold tracking-tight text-slate-900">Compare ETFs</h1>
    <p class="mt-2 max-w-2xl text-slate-600">
      URL-driven:&nbsp;<code class="rounded bg-slate-100 px-1.5 py-0.5 text-xs font-mono">/compare?a=JEPI&b=SCHD&c=VOO</code>
      · Up to three tickers · Data pulls from Yield to Freedom’s Neon snapshot · Verify externally before investing.
    </p>

    <div id="compare-root" class="mt-10 space-y-8" data-catalog={catalogJson} x-data="compareTool()" x-cloak>

      <!-- pillar filter tabs -->
      <div x-show="catalog.length > 0" class="flex flex-wrap gap-2">
        <template x-for="p in pillars" :key="p.value">
          <button
            class="cursor-pointer rounded-full px-3.5 py-1 text-xs font-semibold capitalize transition-colors"
            :class="filterPillar === p.value ? 'bg-blue-600 text-white shadow-sm' : 'bg-slate-100 text-slate-600 hover:bg-slate-200'"
            @click="filterPillar = p.value"
            x-text="p.label"
          ></button>
        </template>
      </div>

      <!-- selectors -->
      <div class="grid gap-4 lg:grid-cols-3" x-show="catalog.length > 0">
        <template x-for="col in [0, 1, 2]" :key="col">
          <div>
            <label class="block text-xs font-semibold uppercase text-slate-500">
              <span x-text="labelFor(col)"></span>
            </label>
            <div class="relative mt-2 flex items-center gap-2">
              <span
                class="inline-block h-3 w-3 flex-none rounded-sm"
                :style="`background: ${lineColors[col]}`"
              ></span>
              <select
                class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-medium text-slate-900"
                x-model="tickers[col]"
                @change="onTickerChange(col)"
              >
                <option value="">(none)</option>
                <template x-for="row in filteredCatalogForCol(col)" :key="row.ticker">
                  <option
                    :value="row.ticker"
                    x-text="optionLabel(row)"
                  ></option>
                </template>
              </select>
            </div>
            <template x-if="tickers[col] && errors[tickers[col]]">
              <p class="mt-1 text-xs text-rose-700" x-text="errors[tickers[col]]"></p>
            </template>
          </div>
        </template>
      </div>

      <noscript class="block rounded-xl border border-amber-400 bg-amber-50 px-4 py-3 text-sm text-amber-900">
        Compare tool needs JavaScript · open individual profiles from <a class="underline" href="/etfs">the directory</a>.
      </noscript>

      <div class="rounded-xl border border-slate-200 bg-slate-50/60 px-4 py-3 text-sm text-slate-600" x-cloak>
        <p x-show="loading">Loading snapshots…</p>
      </div>

      <!-- chart -->
      <section class="rounded-2xl border border-slate-100 bg-white p-5 shadow-sm" x-show="usableTickers().length >= 2" x-cloak>
        <div class="flex flex-wrap items-start justify-between gap-4">
          <!-- mode / range toggles -->
          <div class="flex flex-wrap gap-2">
            <div class="flex rounded-lg border border-slate-200 bg-slate-50 p-0.5 text-sm font-medium">
              <button
                class="cursor-pointer rounded-md px-4 py-1.5 transition-colors"
                :class="chartMode === 'price' ? 'bg-white text-slate-900 shadow-sm' : 'text-slate-500 hover:text-slate-700'"
                @click="chartMode = 'price'; renderChartOverlay()"
              >Price</button>
              <button
                class="cursor-pointer rounded-md px-4 py-1.5 transition-colors"
                :class="chartMode === 'total-return' ? 'bg-white text-slate-900 shadow-sm' : 'text-slate-500 hover:text-slate-700'"
                @click="chartMode = 'total-return'; renderChartOverlay()"
              >Total Return</button>
            </div>
            <div class="flex rounded-lg border border-slate-200 bg-slate-50 p-0.5 text-xs font-medium">
              <template x-for="range in ['1y', '3y', '5y', '10y', 'max']" :key="range">
                <button
                  class="cursor-pointer rounded-md px-2.5 py-1.5 uppercase transition-colors"
                  :class="chartRange === range ? 'bg-white text-slate-900 shadow-sm' : 'text-slate-500 hover:text-slate-700'"
                  @click="chartRange = range; void pullData()"
                  x-text="range === 'max' ? 'Max' : range"
                ></button>
              </template>
            </div>
          </div>
          <!-- color legend -->
          <div class="flex flex-wrap gap-x-5 gap-y-1.5 text-sm">
            <template x-for="(tk, i) in usableTickers()" :key="tk">
              <div class="flex items-center gap-2 font-medium text-slate-700">
                <svg width="24" height="4" class="flex-none overflow-visible">
                  <line x1="0" y1="2" x2="24" y2="2" :stroke="lineColors[i]" stroke-width="2.5" stroke-linecap="round"/>
                </svg>
                <span x-text="tk" class="font-mono text-xs tracking-tight"></span>
              </div>
            </template>
          </div>
        </div>
        <p class="mt-1.5 text-xs text-slate-400" x-text="chartMode === 'total-return' ? 'Adjusted close total return · % return from selected start' : 'Adjusted close · % return from selected start'"></p>
        <!-- data range notice -->
        <template x-if="chartDataRanges().length > 0">
          <p class="mt-2 text-xs text-slate-500" x-html="'Data from: ' + chartDataRanges().join(' &nbsp;·&nbsp; ')"></p>
        </template>
        <!-- excluded notice -->
        <template x-if="noDataFor.length > 0">
          <p class="mt-3 text-xs text-amber-700 bg-amber-50 rounded px-3 py-1.5">
            No price history for: <span class="font-mono font-semibold" x-text="noDataFor.join(', ')"></span> - run <code>npm run backfill:prices</code> to populate.
          </p>
        </template>
        <div class="relative mt-5 h-72 w-full sm:h-80">
          <canvas id={CANVAS_ID} class="absolute inset-0 max-h-full w-full"></canvas>
        </div>
      </section>

      <!-- grid -->
      <section x-show="usableTickers().length > 0" x-cloak>
        <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500">Metrics snapshot</h2>
        <div class="-mx-4 overflow-x-auto pb-4 sm:mx-0">
          <table class="mt-4 min-w-[760px] w-full divide-y divide-slate-100 text-left text-sm">
            <thead>
              <tr class="divide-x divide-slate-100 bg-slate-50 text-xs font-semibold uppercase text-slate-500">
                <th class="sticky left-0 z-10 w-52 bg-slate-50 px-4 py-3">Metric</th>
                <template x-for="t in usableTickers()" :key="t">
                  <th class="px-4 py-3 font-mono tracking-tight" x-text="t"></th>
                </template>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white">
              <template x-for="row in gridRows()" :key="row.key">
                <tr class="divide-x divide-slate-100 hover:bg-blue-50/30">
                  <td class="sticky left-0 bg-white px-4 py-2.5 font-medium text-slate-700" x-text="row.label"></td>
                  <template x-for="t in usableTickers()" :key="`${row.key}_${t}`">
                    <td class="bg-white px-4 py-2.5 text-slate-800" x-html="cellHtml(t, row)"></td>
                  </template>
                </tr>
              </template>
            </tbody>
          </table>
        </div>
      </section>

      <p class="text-sm text-slate-500">
        Columns update the address bar silently so you can bookmark or paste a preset - no account required.
      </p>

      <Disclaimer />
    </div>
  </article>
</Base>

<script>
  import Alpine from 'alpinejs';

  import { mountCompareYieldChartFromPayload } from '../../lib/charts/compare-yield-line';

  const LINE_COLORS = ['rgb(37, 99, 235)', 'rgb(217, 119, 6)', 'rgb(22, 163, 74)'];

  interface CatalogRow {
    ticker: string;
    name: string;
    pillar: string;
    category: string | null;
  }

  interface EtfApiRow {
    ticker: string;
    name: string;
    pillar: string;
    category: string | null;
    issuer: string | null;
    lastPrice: string | null;
    lastYield: string | null;
    trailing12mYield: string | null;
    expenseRatio: string | null;
    aum: string | null;
    dividendFrequency: string | null;
    dripEligible: boolean | null;
    incomeSynthetic: boolean | null;
    ytfGrade: string | null;
    ytfScore: string | null;
    return1y: string | null;
    return3y: string | null;
    return5y: string | null;
    inceptionDate: string | null;
    dataLastSynced: string | null;
    exchange: string | null;
    [key: string]: unknown;
  }

  function pctFromDecimal(s: unknown, digits = 2): string {
    if (s === null || s === undefined || s === '') return '-';
    const n = Number(s);
    if (!Number.isFinite(n)) return '-';
    return `${(n * 100).toFixed(digits)}%`;
  }

  function pctFromTrailingDecimalYield(s: unknown): string {
    /** stored values are already fractional yield (same as ETF page) */
    return pctFromDecimal(s, 2);
  }

  function fmtUsdAmount(s: unknown): string {
    if (s === null || s === undefined || s === '') return '-';
    const v = Number(s);
    if (!Number.isFinite(v)) return '-';
    return `$${v.toLocaleString(undefined, { maximumFractionDigits: 4 })}`;
  }

  function fmtBillions(s: unknown): string {
    if (s === null || s === undefined || s === '') return '-';
    const v = Number(s);
    if (!Number.isFinite(v)) return '-';
    if (v >= 1e9) return `$${(v / 1e9).toFixed(2)}B`;
    if (v >= 1e6) return `$${(v / 1e6).toFixed(2)}M`;
    return `$${v.toLocaleString()}`;
  }

  document.addEventListener('alpine:init', () => {
    Alpine.data('compareTool', () => ({
      tickers: ['', '', ''] as string[],
      catalog: [] as CatalogRow[],
      filterPillar: 'all' as string,
      chartMode: 'price' as 'price' | 'total-return',
      chartRange: '5y' as '1y' | '3y' | '5y' | '10y' | 'max',
      lineColors: LINE_COLORS,
      pillars: [
        { value: 'all', label: 'All ETFs' },
        { value: 'income', label: 'Income' },
        { value: 'stability', label: 'Stability' },
        { value: 'growth', label: 'Growth' },
      ],
      etfByTicker: {} as Record<string, EtfApiRow | undefined>,
      priceHistByTicker: {} as Record<string, { pricePoints: Array<{ x: number; value: number }>; totalReturnPoints: Array<{ x: number; value: number }> }>,
      errors: {} as Record<string, string | undefined>,
      noDataFor: [] as string[],
      loading: false,
      CANVAS_ID: 'ytf-compare-yield-chart',

      /** Pillar tabs filter the pick list; each slot only adds its own value if missing (not all three slots). */
      filteredCatalogForCol(col: number): CatalogRow[] {
        const base =
          this.filterPillar === 'all'
            ? this.catalog
            : this.catalog.filter((r: CatalogRow) => r.pillar === this.filterPillar);
        const pick = String(this.tickers[col] ?? '')
          .trim()
          .toUpperCase();
        if (!pick) return base;
        if (base.some((r: CatalogRow) => r.ticker.toUpperCase() === pick)) return base;
        const row = this.catalog.find((r: CatalogRow) => r.ticker.toUpperCase() === pick);
        return row ? [...base, row] : base;
      },

      optionLabel(row: CatalogRow): string {
        const title = row.name.length > 32 ? `${row.name.slice(0, 32)}…` : row.name;
        const cat = row.category ? String(row.category).replace(/-/g, ' ') : '';
        const tail = cat ? ` · ${row.pillar} · ${cat}` : ` · ${row.pillar}`;
        return `${row.ticker} — ${title}${tail}`;
      },

      tickerSet(): Set<string> {
        const s = new Set<string>();
        this.catalog.forEach((r: CatalogRow) => s.add(r.ticker.toUpperCase()));
        return s;
      },

      labelFor(col: number) {
        const k = ['A', 'B', 'C'][col];
        return `ETF (${k ?? col})`;
      },

      qsFromSlots() {
        const u = new URL(window.location.href);
        ['a', 'b', 'c'].forEach((param, ix) => {
          const tk = String(this.tickers[ix] ?? '').trim().toUpperCase();
          if (tk) u.searchParams.set(param, tk);
          else u.searchParams.delete(param);
        });
        return u.pathname + u.search + u.hash;
      },

      refreshUrlQuietly() {
        const next = this.qsFromSlots();
        if (`${window.location.pathname}${window.location.search}${window.location.hash}` !== next) {
          window.history.replaceState({}, '', next);
        }
      },

      readInitialFromQs(): string[] {
        const sp = new URLSearchParams(window.location.search);
        const valid = this.tickerSet();
        const norm = (s: string | null) => String(s ?? '').trim().toUpperCase();
        let a = norm(sp.get('a'));
        let b = norm(sp.get('b'));
        let c = norm(sp.get('c'));
        a = valid.has(a) ? a : '';
        b = valid.has(b) ? b : '';
        c = valid.has(c) ? c : '';

        if (!a && !b && !c) {
          if (valid.has('JEPI') && valid.has('SCHD')) { a = 'JEPI'; b = 'SCHD'; }
          else if (this.catalog.length >= 2) {
            a = this.catalog[0]!.ticker;
            b = this.catalog[1]!.ticker;
          } else if (this.catalog.length === 1) {
            a = this.catalog[0]!.ticker;
          }
        }

        return [a, b, c];
      },

      uniqTickersList(): string[] {
        const out: string[] = [];
        const seen = new Set<string>();
        for (let i = 0; i < 3; i++) {
          const t = String(this.tickers[i] ?? '').trim().toUpperCase();
          if (!t || seen.has(t)) continue;
          seen.add(t);
          out.push(t);
        }
        return out;
      },

      usableTickers(): string[] {
        return this.uniqTickersList();
      },

      pillarHTML(pillar: string): string {
        const cls: Record<string, string> = {
          income: 'bg-orange-50 text-orange-900 ring-orange-700/25',
          stability: 'bg-indigo-50 text-indigo-900 ring-indigo-700/25',
          growth: 'bg-teal-50 text-teal-900 ring-teal-700/25',
          mixed: 'bg-slate-50 text-slate-800 ring-slate-700/25',
        };
        const ring = cls[pillar] ?? cls['mixed'];
        const label = pillar || 'mixed';
        return `<span class="inline-flex rounded-full px-2.5 py-0.5 text-xs font-semibold capitalize ring-1 ring-inset ${ring}">${label}</span>`;
      },

      gradeHTML(g: unknown): string {
        const k = String(g ?? '').trim().toUpperCase();
        if (!k) return `<span class="text-xs text-slate-400">-</span>`;
        const tiers: Record<string, string> = {
          A: 'bg-emerald-100 text-emerald-900',
          B: 'bg-sky-100 text-sky-900',
          C: 'bg-amber-100 text-amber-900',
          D: 'bg-rose-100 text-rose-900',
        };
        const c = tiers[k] ?? 'bg-slate-100 text-slate-700';
        return `<span class="inline-flex min-h-6 min-w-6 items-center justify-center rounded px-2 py-0.5 text-xs font-bold ring-1 ring-black/10 ${c}">${k}</span>`;
      },

      /** rows for tbody */
      gridRows(): Array<{ key: string; label: string }> {
        return [
          { key: 'name', label: 'Name' },
          { key: 'pillar', label: 'Pillar' },
          { key: 'grade', label: 'YTF grade' },
          { key: 't12', label: 'Trailing 12-mo yield' },
          { key: 'er', label: 'Expense ratio' },
          { key: 'price', label: 'Last price' },
          { key: 'aum', label: 'Approx size (market cap)**' },
          { key: 'fq', label: 'Dividend frequency' },
          { key: 'drip', label: 'DRIP eligible' },
          { key: 'synth', label: 'Synthetic income?' },
          { key: 'r1', label: 'Return 1Y' },
          { key: 'r3', label: 'Return 3Y' },
          { key: 'r5', label: 'Return 5Y' },
          { key: 'inception', label: 'Inception' },
          { key: 'sync', label: 'Data as of' },
        ];
      },

      cellHtml(t: string, row: { key: string }): string {
        const rowData = this.etfByTicker[t];
        const err = this.errors[t];
        if (err) return `<span class="text-rose-700">${err}</span>`;
        if (!rowData) return `<span class="text-slate-400">-</span>`;
        switch (row.key) {
          case 'name':
            return `<a class="font-medium text-blue-800 hover:text-blue-950" href="/etfs/${t}">${escapeHtml(rowData.name ?? '')}</a>`;
          case 'pillar':
            return this.pillarHTML(String(rowData.pillar ?? ''));
          case 'grade':
            return this.gradeHTML(rowData.ytfGrade) +
              (rowData.ytfScore
                ? ` <span class="ml-1 text-xs tabular-nums text-slate-500">(${escapeHtml(String(rowData.ytfScore))})</span>`
                : '');
          case 't12':
            return escapeHtml(pctFromTrailingDecimalYield(rowData.trailing12mYield));
          case 'er':
            return escapeHtml(pctFromDecimal(rowData.expenseRatio, 3));
          case 'price':
            return escapeHtml(fmtUsdAmount(rowData.lastPrice));
          case 'aum':
            return escapeHtml(fmtBillions(rowData.aum));
          case 'fq':
            return `<span class="capitalize">${escapeHtml(String(rowData.dividendFrequency ?? '-'))}</span>`;
          case 'drip':
            return rowData.dripEligible ? `<span class="text-teal-800">Yes*</span>` : `<span>No*</span>`;
          case 'synth':
            return rowData.incomeSynthetic ? `<span class="text-amber-900">Yes</span>` : `<span>No</span>`;
          case 'r1':
            return escapeHtml(pctFromDecimal(rowData.return1y, 2));
          case 'r3':
            return escapeHtml(pctFromDecimal(rowData.return3y, 2));
          case 'r5':
            return escapeHtml(pctFromDecimal(rowData.return5y, 2));
          case 'inception':
            return escapeHtml(rowData.inceptionDate ? String(rowData.inceptionDate).slice(0, 10) : '-');
          case 'sync':
            return escapeHtml(
              rowData.dataLastSynced != null ? String(rowData.dataLastSynced).slice(0, 10) : '-',
            );
          default:
            return '-';
        }
      },

      onTickerChange(col: number) {
        // Deduplicate: clear any other slot that already has this ticker
        const chosen = String(this.tickers[col] ?? '').trim().toUpperCase();
        if (chosen) {
          for (let i = 0; i < 3; i++) {
            if (i !== col && String(this.tickers[i] ?? '').trim().toUpperCase() === chosen) {
              this.tickers[i] = '';
            }
          }
        }
        this.refreshUrlQuietly();
        this.scheduleLoad();
      },

      scheduleLoad() {
        if ((this as { _loadTimer?: number })._loadTimer) {
          window.clearTimeout((this as { _loadTimer?: number })._loadTimer!);
        }
        (
          this as {
            _loadTimer?: number;
          }
        )._loadTimer = window.setTimeout(async () => {
          await this.pullData();
          (this as { _loadTimer?: number })._loadTimer = undefined;
        }, 120);
      },

      chartDataRanges(): string[] {
        return this.usableTickers().map((tk: string) => {
          const pts = this.priceHistByTicker[tk]?.pricePoints ?? [];
          if (!pts.length) return '';
          const first = new Date((pts[0] as { x: number }).x).toISOString().slice(0, 7);
          return `<span class="font-mono">${tk}</span> ${first}`;
        }).filter(Boolean);
      },

      renderChartOverlay() {
        const tickersOrdered = this.uniqTickersList();

        const datasets = tickersOrdered.map((tk: string, i: number) => {
          const hist = this.priceHistByTicker[tk];
          if (this.chartMode === 'total-return') {
            const pts = hist?.totalReturnPoints ?? [];
            return {
              label: tk,
              borderColor: LINE_COLORS[i % LINE_COLORS.length] ?? LINE_COLORS[0]!,
              points: pts.map((p: { x: number; value: number }) => ({ x: p.x, y: p.value })),
            };
          }
          // Price mode: normalize to % change from first point so ETFs at different price levels are comparable
          const pts = hist?.pricePoints ?? [];
          const firstVal = pts[0]?.value ?? 1;
          return {
            label: tk,
            borderColor: LINE_COLORS[i % LINE_COLORS.length] ?? LINE_COLORS[0]!,
            points: pts.map((p: { x: number; value: number }) => ({ x: p.x, y: ((p.value / firstVal) - 1) * 100 })),
          };
        });

        const result = mountCompareYieldChartFromPayload({
          canvasId: this.CANVAS_ID,
          datasets,
          yMode: 'pct',
        });
        this.noDataFor = result.excluded;
      },

      async pullData() {
        const list = this.uniqTickersList();
        this.loading = true;

        type PriceHist = { pricePoints: Array<{ x: number; value: number }>; totalReturnPoints: Array<{ x: number; value: number }> };
        const nextEtf: Record<string, EtfApiRow | undefined> = {};
        const nextHist: Record<string, PriceHist> = {};

        await Promise.all(
          list.map(async (tk: string) => {
            delete this.errors[tk];
            nextEtf[tk] = undefined;
            nextHist[tk] = { pricePoints: [], totalReturnPoints: [] };

            try {
              const res = await fetch(`/api/etfs/${encodeURIComponent(tk)}`);
              if (!res.ok)
                throw new Error(res.status === 404 ? `Unknown ticker “${tk}”.` : `HTTP ${res.status}`);
              nextEtf[tk] = (await res.json()) as EtfApiRow;
            } catch (e) {
              const msg = e instanceof Error ? e.message : 'Load failed.';
              this.errors[tk] = msg;
            }

            if (this.errors[tk]) return;

            try {
              const hr = await fetch(`/api/etfs/${encodeURIComponent(tk)}/price-history?range=${this.chartRange}`);
              if (hr.ok) {
                const body = (await hr.json()) as { pricePoints?: unknown; totalReturnPoints?: unknown };
                if (Array.isArray(body.pricePoints)) nextHist[tk]!.pricePoints = body.pricePoints as PriceHist['pricePoints'];
                if (Array.isArray(body.totalReturnPoints)) nextHist[tk]!.totalReturnPoints = body.totalReturnPoints as PriceHist['totalReturnPoints'];
              }
            } catch {
              /* price history stays empty - metrics table still renders */
            }
          }),
        );

        this.etfByTicker = {};
        this.priceHistByTicker = {};

        const keep = new Set(list);
        for (const tk of keep) {
          if (!this.errors[tk] && nextEtf[tk]) this.etfByTicker[tk] = nextEtf[tk];
          this.priceHistByTicker[tk] = nextHist[tk] ?? { pricePoints: [], totalReturnPoints: [] };
        }

        this.loading = false;
        queueMicrotask(() => this.renderChartOverlay());
      },

      init() {
        const root = document.getElementById('compare-root');
        this.catalog = JSON.parse(root?.dataset.catalog ?? '[]') as CatalogRow[];

        const slots = this.readInitialFromQs();
        const seen = new Set<string>();
        for (let i = 0; i < 3; i++) {
          const t = slots[i]?.trim().toUpperCase() ?? '';
          if (t && !seen.has(t)) {
            this.tickers[i] = t;
            seen.add(t);
          } else {
            this.tickers[i] = '';
          }
        }

        this.refreshUrlQuietly();
        queueMicrotask(() => this.pullData());
      },
    }));
  });

  function escapeHtml(s: string): string {
    return String(s ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;');
  }

  Alpine.start();
</script>
