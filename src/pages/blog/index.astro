---
import { getCollection } from 'astro:content';

import Base from '../../layouts/Base.astro';
import { publicSiteOrigin } from '../../lib/site/url';

const site = publicSiteOrigin();
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Yield to Freedom — Income ETF research',
  description: 'Articles on income ETFs, dividends, and our 40/30/30 framework — educational, not advice.',
  url: `${site}/blog`,
  publisher: { '@type': 'Organization', name: 'Creative Bandit LLC', url: site },
};
---

<Base
  title="Blog — Yield to Freedom"
  description="Research notes and explainers on income ETFs, dividends, and building cash-flow-oriented portfolios."
  schema={schema}
>
  <article class="max-w-3xl">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900">Blog</h1>
    <p class="mt-2 text-slate-600">
      Long-form notes that pair with our [ETF directory](/etfs) and [strategy guides](/strategy). Everything here is
      educational — verify data and fit with your own plan.
    </p>

    <ul class="mt-10 space-y-8">
      {
        posts.map((post) => (
          <li class="border-b border-slate-100 pb-8">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
              {post.data.pubDate.toISOString().slice(0, 10)}
            </p>
            <h2 class="mt-2 text-xl font-bold text-slate-900">
              <a class="text-blue-800 hover:text-blue-950" href={`/blog/${post.id}`}>
                {post.data.title}
              </a>
            </h2>
            <p class="mt-2 text-slate-600">{post.data.description}</p>
            {
              post.data.tags?.length ? (
                <p class="mt-3 flex flex-wrap gap-2 text-xs text-slate-500">
                  {post.data.tags.map((t) => (
                    <span class="rounded-full bg-slate-100 px-2 py-0.5 font-medium text-slate-700">{t}</span>
                  ))}
                </p>
              ) : null
            }
          </li>
        ))
      }
    </ul>

    {
      posts.length === 0 ? (
        <p class="mt-10 text-slate-500">No posts yet — check back soon.</p>
      ) : null
    }
  </article>
</Base>
