---
import { getCollection } from 'astro:content';

import Base from '../../layouts/Base.astro';
import { publicSiteOrigin } from '../../lib/site/url';

const site = publicSiteOrigin();
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Yield to Freedom — Income ETF research',
  description: 'Articles on income ETFs, dividends, and our 40/30/30 framework — educational, not advice.',
  url: `${site}/blog`,
  publisher: { '@type': 'Organization', name: 'Creative Bandit LLC', url: site },
};
---

<Base
  title="Blog — Yield to Freedom"
  description="Research notes and explainers on income ETFs, dividends, and building cash-flow-oriented portfolios."
  schema={schema}
>
  <div class="max-w-5xl">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900">Blog</h1>
    <p class="mt-2 text-slate-600">
      Long-form notes that pair with our <a class="font-semibold text-blue-700 hover:text-blue-900" href="/etfs">ETF directory</a> and <a class="font-semibold text-blue-700 hover:text-blue-900" href="/strategy">strategy guides</a>. Everything here is
      educational — verify data and fit with your own plan.
    </p>

    {
      posts.length === 0 ? (
        <p class="mt-10 text-slate-500">No posts yet — check back soon.</p>
      ) : (
        <ul class="mt-10 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <li class="group flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition-shadow hover:shadow-md">
              <a href={`/blog/${post.id}`} class="block" tabindex="-1" aria-hidden="true">
                <div class="relative aspect-[16/9] overflow-hidden bg-slate-100">
                  {post.data.image ? (
                    <img
                      src={post.data.image}
                      alt={post.data.imageAlt ?? post.data.title}
                      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                  ) : (
                    <div class="flex h-full items-center justify-center bg-slate-100">
                      <svg class="h-10 w-10 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3 4.5h18M3 19.5h18" />
                      </svg>
                    </div>
                  )}
                </div>
              </a>
              <div class="flex flex-1 flex-col p-5">
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
                  {post.data.pubDate.toISOString().slice(0, 10)}
                </p>
                <h2 class="mt-2 text-lg font-bold leading-snug text-slate-900">
                  <a class="hover:text-blue-800" href={`/blog/${post.id}`}>
                    {post.data.title}
                  </a>
                </h2>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600 line-clamp-3">
                  {post.data.description}
                </p>
                {post.data.tags?.length ? (
                  <p class="mt-3 flex flex-wrap gap-1.5 text-xs text-slate-500">
                    {post.data.tags.map((t) => (
                      <span class="rounded-full bg-slate-100 px-2 py-0.5 font-medium text-slate-700">{t}</span>
                    ))}
                  </p>
                ) : null}
                <a
                  href={`/blog/${post.id}`}
                  class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-blue-700 hover:text-blue-900"
                >
                  Read more <span aria-hidden="true">→</span>
                </a>
              </div>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</Base>
