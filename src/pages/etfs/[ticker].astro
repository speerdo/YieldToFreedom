---
import { and, asc, desc, eq, ne } from 'drizzle-orm';

import DividendChart from '../../components/etf/DividendChart.astro';
import PriceReturnChart from '../../components/etf/PriceReturnChart.astro';
import Badge from '../../components/ui/Badge.astro';
import Card from '../../components/ui/Card.astro';
import Disclaimer from '../../components/ui/Disclaimer.astro';
import GradeChip from '../../components/ui/GradeChip.astro';
import Base from '../../layouts/Base.astro';
import { db } from '../../lib/db';
import { etfDividends, etfs } from '../../lib/db/schema';

export async function getStaticPaths() {
  const all = await db
    .select({ ticker: etfs.ticker })
    .from(etfs)
    .where(eq(etfs.isActive, true));
  return all.map(({ ticker }) => ({ params: { ticker } }));
}

const raw = Astro.params.ticker;
if (!raw) return Astro.redirect('/etfs');
const ticker = raw.toUpperCase();

const [etf] = await db.select().from(etfs).where(eq(etfs.ticker, ticker)).limit(1);
if (!etf) return Astro.redirect('/etfs');

const dividends = await db
  .select()
  .from(etfDividends)
  .where(eq(etfDividends.etfId, etf.id))
  .orderBy(desc(etfDividends.exDate))
  .limit(120);

// ── Distribution stats ────────────────────────────────────────────────────────
const now = new Date();
const oneYearAgo  = new Date(now.getFullYear() - 1, now.getMonth(), now.getDate()).toISOString().slice(0, 10);
const twoYearsAgo = new Date(now.getFullYear() - 2, now.getMonth(), now.getDate()).toISOString().slice(0, 10);
const dividendAmount = (d: typeof dividends[number]) => Number(d.adjAmount ?? d.amount);

// Detect special / anomalous distributions so they do not distort the trend
// signal. We flag any payment whose size is far off the typical (median)
// regular payment. This catches year-end specials and one-off distributions
// (the +222 % / -64.9 % single-period swings the spec calls out) without
// requiring a per-row "special" flag from the data source.
const amounts = dividends.map((d) => dividendAmount(d)).filter((n) => Number.isFinite(n) && n > 0).sort((a, b) => a - b);
const medianAmount =
  amounts.length === 0
    ? 0
    : amounts.length % 2 === 1
      ? amounts[(amounts.length - 1) / 2]!
      : (amounts[amounts.length / 2 - 1]! + amounts[amounts.length / 2]!) / 2;
const specialThresholdHigh = medianAmount > 0 ? medianAmount * 2.5 : Infinity; // 2.5x median
const specialThresholdLow  = medianAmount > 0 ? medianAmount * 0.4 : 0;         // 0.4x median
function isSpecial(amount: number): boolean {
  if (!Number.isFinite(medianAmount) || medianAmount <= 0) return false;
  return amount > specialThresholdHigh || amount < specialThresholdLow;
}

const ttmDivs  = dividends.filter((d) => String(d.exDate) >= oneYearAgo);
const ttmSum   = ttmDivs.reduce((s, d) => s + dividendAmount(d), 0);
const recentSix = dividends.slice(0, 6);
const avgPayment = recentSix.length
  ? recentSix.reduce((s, d) => s + dividendAmount(d), 0) / recentSix.length
  : 0;

// Distribution trend: trailing-12-month distributions vs prior trailing-12-month
// distributions (year over year), excluding special / anomalous payments so
// a single one-off payout can't flip a dividend grower to "Declining".
const ttmSumReg  = ttmDivs.filter((d) => !isSpecial(dividendAmount(d))).reduce((s, d) => s + dividendAmount(d), 0);
const priorTtmDivs = dividends.filter((d) => {
  const dt = String(d.exDate);
  return dt >= twoYearsAgo && dt < oneYearAgo;
});
const priorTtmSumReg = priorTtmDivs.filter((d) => !isSpecial(dividendAmount(d))).reduce((s, d) => s + dividendAmount(d), 0);

let distTrend = 'Stable';
let trendCls  = 'bg-slate-100 text-slate-600';
let trendDetail = 'Based on last 12 months';
if (priorTtmSumReg > 0) {
  const chg = (ttmSumReg - priorTtmSumReg) / priorTtmSumReg;
  if (chg >  0.02) { distTrend = '↑ Growing';  trendCls = 'bg-emerald-100 text-emerald-800'; trendDetail = `TTM up ${Math.round(chg * 100)}% YoY`; }
  if (chg < -0.05) { distTrend = '↓ Declining'; trendCls = 'bg-rose-100    text-rose-800';    trendDetail = `TTM down ${Math.round(-chg * 100)}% YoY`; }
  if (distTrend === 'Stable') trendDetail = `TTM within 5% of prior year`;
} else if (dividends.length > 0) {
  trendDetail = 'Less than 2 years of history';
}

// Payment streak: consecutive payments not below 98 % of the prior one


// Projected annual per share using recent average × inferred payment count
const PPY: Record<string, number> = { weekly: 52, monthly: 12, quarterly: 4, 'semi-annual': 2, annual: 1 };
const ppy = PPY[etf.dividendFrequency ?? ''] ?? Math.max(ttmDivs.length, 1);
const projectedAnnual = avgPayment * ppy;

// Bar chart data (ascending for display)
const chartOrdered = [...dividends].sort((a, b) => String(a.exDate).localeCompare(String(b.exDate)));
const chartLabels  = chartOrdered.map((d) => String(d.exDate));
const chartAmounts = chartOrdered.map((d) => dividendAmount(d));

// ── Helpers ───────────────────────────────────────────────────────────────────
function fmtPct(decStr: string | null | undefined, digits = 2): string {
  if (decStr == null || decStr === '') return '-';
  const v = Number(decStr);
  if (!Number.isFinite(v)) return '-';
  return `${(v * 100).toFixed(digits)}%`;
}

function fmtBillionsUsd(decStr: string | null | undefined): string {
  if (decStr == null || decStr === '') return '-';
  const v = Number(decStr);
  if (!Number.isFinite(v)) return '-';
  if (v >= 1e9) return `$${(v / 1e9).toFixed(2)}B`;
  if (v >= 1e6) return `$${(v / 1e6).toFixed(2)}M`;
  return `$${v.toLocaleString()}`;
}

function fmtUsd(n: number, digits = 4): string {
  if (!Number.isFinite(n) || n === 0) return '-';
  return `$${n.toFixed(digits)}`;
}

function fmtUsdWhole(n: number): string {
  if (!Number.isFinite(n)) return '-';
  return `$${Math.round(n).toLocaleString()}`;
}

// ETF descriptions are stored as a single run-on string of text (no newlines
// or breaks), so we split on sentence boundaries and group consecutive
// sentences into readable paragraphs (target ~360-620 chars each). Splitting
// avoids false sentence boundaries inside common abbreviations like "Inc.",
// "U.S.", "LLC.", "Corp.", "S&P" (the trailing S.) so that text continues
// naturally after "Apple Inc. designs..." instead of breaking mid-sentence.
const SENTENCE_END_ABBREVIATIONS = new Set([
  'inc', 's', 'co', 'ltd', 'corp', 'no', 'mr', 'mrs', 'ms', 'dr', 'st',
  'vs', 'jr', 'sr', 'llc', 'lp', 'plc', 'pm', 'am', 'etc', 'approx',
  'fig', 'vol', 'pp', 'op', 'ed', 'trans', 'assoc', 'bros', 'dept',
  'est', 'mo', 'yr', 'min', 'max', 'avg', 'sm', 'tm',
]);

function splitSentences(text: string): string[] {
  // Find every [.!?] + whitespace + (Capital letter | digit | opening quote).
  // Skip split points where the punctuation is the end of a known abbreviation
  // ("Inc.", "U.S.", "LLC.", single capital letter like "S." in "U.S.").
  const splits: number[] = [];
  const re = /([.!?])\s+(?=[A-Z0-9\u201C\u201D"])/g;
  let m: RegExpExecArray | null;
  while ((m = re.exec(text))) {
    const periodIdx = m.index;
    // Examine the token immediately preceding the punctuation.
    const preceding = text.slice(0, periodIdx).match(/([A-Za-z.]+)$/);
    let isAbbrev = false;
    if (preceding) {
      const token = preceding[1]!;
      // Single capital letter (e.g. "S" in "U.S") => abbreviation tail.
      if (/^[A-Z]$/.test(token)) isAbbrev = true;
      const word = token.replace(/\./g, '').toLowerCase();
      if (SENTENCE_END_ABBREVIATIONS.has(word)) isAbbrev = true;
      // Explicit "U.S." pattern: prior chars look like "U.S"
      const tail = text.slice(Math.max(0, periodIdx - 3), periodIdx + 1);
      if (/U\.S$/i.test(tail.slice(0, -1))) isAbbrev = true;
    }
    if (!isAbbrev) splits.push(m.index + 1);
  }
  if (splits.length === 0) return [text.trim()].filter(Boolean);
  const out: string[] = [];
  let last = 0;
  for (const idx of splits) {
    out.push(text.slice(last, idx).trim());
    last = idx;
  }
  out.push(text.slice(last).trim());
  return out.filter(Boolean);
}

function descriptionParagraphs(text: string | null | undefined): string[] {
  if (!text) return [];
  const clean = text.replace(/\s+/g, ' ').trim();
  if (!clean) return [];
  const sentences = splitSentences(clean);
  if (sentences.length === 0) return [clean];

  const paragraphs: string[] = [];
  let buf = '';
  const MIN = 360;
  const MAX = 620;
  for (const s of sentences) {
    const candidate = buf ? `${buf} ${s}` : s;
    if (!buf) {
      buf = s;
      // A single very long sentence stands alone as its own paragraph.
      if (buf.length >= MAX) {
        paragraphs.push(buf);
        buf = '';
      }
      continue;
    }
    // Once we're in the target band, flush before adding a sentence that
    // would push us past the max — keeps paragraphs in a readable range.
    if (buf.length >= MIN && candidate.length > MAX) {
      paragraphs.push(buf);
      buf = s;
    } else {
      buf = candidate;
      if (buf.length >= MAX) {
        paragraphs.push(buf);
        buf = '';
      }
    }
  }
  if (buf) paragraphs.push(buf);
  return paragraphs;
}

// ── Related ETFs ──────────────────────────────────────────────────────────────
const related = await db
  .select()
  .from(etfs)
  .where(and(eq(etfs.isActive, true), eq(etfs.pillar, etf.pillar), ne(etfs.id, etf.id)))
  .orderBy(asc(etfs.ticker))
  .limit(8);

const site = 'https://yieldtofreedom.com';
const pageUrl = `${site}/etfs/${etf.ticker}`;

// Build a human-readable description that's useful as a meta description
const yieldStr = etf.trailing12mYield ? `${(Number(etf.trailing12mYield) * 100).toFixed(2)}% TTM yield` : null;
const expStr = etf.expenseRatio ? `${(Number(etf.expenseRatio) * 100).toFixed(2)}% expense ratio` : null;
const freqStr = etf.dividendFrequency ? `${etf.dividendFrequency} distributions` : null;
const metaParts = [yieldStr, expStr, freqStr].filter(Boolean);
// Prefer the first ~120 chars of the fund's own description for the meta tag, falling back to generated text
const descText = etf.description
  ? `${etf.description.slice(0, 120).trimEnd()}… ${metaParts.length ? `(${metaParts.join(', ')})` : ''} on Yield to Freedom.`
  : metaParts.length
    ? `${etf.name} (${etf.ticker}): ${metaParts.join(', ')}. Income ETF research, payout history & tools on Yield to Freedom.`
    : `${etf.name} (${etf.ticker}) - income ETF research, payout history, and analysis on Yield to Freedom.`;

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'FinancialProduct',
      '@id': `${pageUrl}#etf`,
      name: etf.name,
      tickerSymbol: etf.ticker,
      description: descText.slice(0, 200),
      url: pageUrl,
      ...(etf.issuer ? { provider: { '@type': 'Organization', name: etf.issuer } } : {}),
      ...(etf.exchange ? { exchangeCode: etf.exchange } : {}),
      ...(etf.inceptionDate ? { foundingDate: String(etf.inceptionDate) } : {}),
      ...(etf.trailing12mYield
        ? {
            annualPercentageRate: {
              '@type': 'QuantitativeValue',
              value: (Number(etf.trailing12mYield) * 100).toFixed(4),
              unitCode: 'P1',
            },
          }
        : {}),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: site },
        { '@type': 'ListItem', position: 2, name: 'ETFs', item: `${site}/etfs` },
        { '@type': 'ListItem', position: 3, name: etf.ticker, item: pageUrl },
      ],
    },
  ],
};

const chartId = `dividend-chart-${etf.ticker}`;

// Values passed to the client-side calculator
const calcYield  = Number(etf.trailing12mYield) || 0;   // decimal e.g. 0.085
const calcPrice  = Number(etf.lastPrice) || 0;
const calcFreq   = etf.dividendFrequency ?? 'monthly';
const periodLabel = calcFreq === 'weekly'
  ? 'week'
  : calcFreq === 'quarterly'
    ? 'quarter'
    : calcFreq === 'semi-annual'
      ? '6 months'
      : calcFreq === 'annual'
        ? 'year'
        : 'month';
const snapshotInvestment = 10_000;
const snapshotAnnual = snapshotInvestment * calcYield;
const snapshotMonthly = snapshotAnnual / 12;
const snapshotPeriod = ppy > 0 ? snapshotAnnual / ppy : 0;
const snapshotShares = calcPrice > 0 ? snapshotInvestment / calcPrice : 0;
const snapshotDripShares = calcPrice > 0 ? snapshotAnnual / calcPrice : 0;
---

<Base
  title={`${etf.ticker} ETF - ${etf.name} | Yield to Freedom`}
  description={descText.slice(0, 160)}
  schema={schema}
>
  <article>

    <!-- ── Hero ────────────────────────────────────────────────────────────── -->
    <div class="flex flex-wrap items-start justify-between gap-6 border-b border-slate-100 pb-8">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-slate-500">ETF profile</p>
        <div class="mt-2 flex flex-wrap items-center gap-3">
          <h1 class="text-4xl font-bold tracking-tight text-slate-900">
            {etf.ticker} <span class="text-2xl font-semibold text-slate-600">— {etf.name}</span>
          </h1>
          <GradeChip grade={etf.ytfGrade} />
        </div>
        <div class="mt-4 flex flex-wrap items-center gap-3">
          <a
            href={`/compare?a=${etf.ticker}`}
            class="text-sm font-medium text-blue-800 underline decoration-blue-800/35 hover:text-blue-950 hover:decoration-blue-950/50"
          >Compare ETFs →</a>
          <Badge label={etf.pillar} pillar={etf.pillar} />
          {etf.category ? <Badge label={etf.category.replace(/-/g, ' ')} pillar="mixed" /> : null}
        </div>
      </div>

      <div class="rounded-xl border border-slate-100 bg-slate-50 px-6 py-4 text-xs text-slate-500">
        <p>YTF grades are research-only - not financial advice.</p>
        {
          etf.dataLastSynced ? (
            <p class="mt-3 font-medium text-slate-700">
              Data as of {(etf.dataLastSynced instanceof Date ? etf.dataLastSynced : new Date(String(etf.dataLastSynced))).toISOString().slice(0, 10)} (Tiingo).
            </p>
          ) : (
            <p class="mt-3 font-medium text-amber-800">Pricing has not synced yet - run nightly sync.</p>
          )
        }
      </div>
    </div>

    {calcYield > 0 && calcPrice > 0 && (
      <section class="mt-10 overflow-hidden rounded-3xl border border-[var(--border)] bg-[var(--bg-card)] text-[var(--fg)] shadow-sm">
        <div class="grid gap-0 lg:grid-cols-[1.05fr_0.95fr]">
          <div class="p-6 sm:p-8">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--link)]">$10k income snapshot</p>
            <h2 class="font-heading mt-3 text-3xl font-bold tracking-tight">
              What could $10,000 in {etf.ticker} do?
            </h2>
            <p class="mt-3 max-w-2xl text-sm leading-relaxed text-[var(--fg-muted)]">
              Using the current trailing 12-month yield, this is the simple cashflow picture: one position, one
              estimated average income stream, and one more step toward your freedom number.
            </p>
            <div class="mt-6 grid gap-3 sm:grid-cols-3">
              <div class="rounded-2xl border border-[var(--border)] bg-[var(--bg-subtle)] p-4">
                <p class="text-xs text-[var(--fg-muted)]">Estimated annual income</p>
                <p class="mt-1 text-3xl font-bold tabular-nums">{fmtUsdWhole(snapshotAnnual)}</p>
              </div>
              <div class="rounded-2xl border border-[var(--border)] bg-[var(--bg-subtle)] p-4">
                <p class="text-xs text-[var(--fg-muted)]">Monthly average</p>
                <p class="mt-1 text-3xl font-bold tabular-nums">{fmtUsdWhole(snapshotMonthly)}</p>
              </div>
              <div class="rounded-2xl border border-[var(--border)] bg-[var(--bg-subtle)] p-4">
                <p class="text-xs text-[var(--fg-muted)]">About per {periodLabel}</p>
                <p class="mt-1 text-3xl font-bold tabular-nums">{fmtUsdWhole(snapshotPeriod)}</p>
              </div>
            </div>
          </div>
          <div class="border-t border-[var(--border)] bg-[var(--bg-subtle)] p-6 sm:p-8 lg:border-l lg:border-t-0">
            <p class="text-sm font-semibold text-[var(--fg)]">DRIP framing</p>
            <p class="mt-2 text-sm leading-relaxed text-[var(--fg-muted)]">
              At today&apos;s price, $10,000 buys about{' '}
              <strong class="text-[var(--fg)]">{snapshotShares.toFixed(1)} shares</strong>. If the estimated distributions
              were reinvested for a year at the same price, DRIP could add roughly{' '}
              <strong class="text-[var(--fg)]">{snapshotDripShares.toFixed(1)} shares</strong> before any market movement.
            </p>
            <p class="mt-4 rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] p-4 text-sm leading-relaxed text-[var(--fg-muted)]">
              Think of each $10k as a cashflow block. Stack enough blocks, diversify the roles, and the portfolio
              starts taking over small monthly bills before it ever replaces a full paycheck.
            </p>
          </div>
        </div>
        <p class="border-t border-[var(--border)] bg-[var(--bg-subtle)] px-6 py-4 text-xs leading-relaxed text-[var(--fg-muted)] sm:px-8">
          Educational estimate only - not financial advice or a recommendation. Figures use this ETF&apos;s trailing
          12-month distributions, latest synced price, and inferred payout cadence from recent data. Actual payments,
          taxes, prices, distribution timing, and future yields can change.
        </p>
      </section>
    )}

    <!-- ── Key metrics ─────────────────────────────────────────────────────── -->
    <div class="mt-10 grid gap-4 sm:grid-cols-2 md:grid-cols-3">
      <Card>
        <p class="text-xs font-semibold uppercase text-slate-500">Last price</p>
        <p class="mt-2 text-2xl font-semibold tabular-nums">
          {calcPrice > 0 ? `$${calcPrice.toFixed(2)}` : '-'}
        </p>
      </Card>
      <Card>
        <p class="text-xs font-semibold uppercase text-slate-500">Trailing 12-mo yield</p>
        <p class="mt-2 text-2xl font-semibold tabular-nums">{fmtPct(etf.trailing12mYield)}</p>
      </Card>
      <Card>
        <p class="text-xs font-semibold uppercase text-slate-500">Expense ratio</p>
        <p class="mt-2 text-2xl font-semibold tabular-nums">{fmtPct(etf.expenseRatio, 3)}</p>
      </Card>
      <Card>
        <p class="text-xs font-semibold uppercase text-slate-500">Approx. AUM</p>
        <p class="mt-2 text-2xl font-semibold tabular-nums">{fmtBillionsUsd(etf.aum)}</p>
      </Card>
      <Card>
        <p class="text-xs font-semibold uppercase text-slate-500">Distribution frequency</p>
        <p class="mt-2 text-2xl font-semibold capitalize">{etf.dividendFrequency ?? '-'}</p>
      </Card>
      <Card>
        <p class="text-xs font-semibold uppercase text-slate-500">YTF grade</p>
        <div class="mt-2"><GradeChip grade={etf.ytfGrade} /></div>
        <p class="mt-2 text-xs tabular-nums text-slate-600">Score {etf.ytfScore ?? '-'} / 100</p>
      </Card>
    </div>

    <!-- ── About ──────────────────────────────────────────────────────────── -->
    {etf.description && (
      <section class="mt-10">
        <h2 class="text-xl font-bold text-slate-900">About {etf.ticker}</h2>
        <div class="mt-3 space-y-3 text-sm leading-relaxed text-slate-700">
          {descriptionParagraphs(etf.description).map((p) => (
            <p>{p}</p>
          ))}
        </div>
      </section>
    )}

    <!-- ── Holdings + Sectors ─────────────────────────────────────────────── -->
    {(etf.holdingsJson || etf.sectorWeightsJson) && (
      <section class="mt-10">
        <div class="grid gap-6 lg:grid-cols-2">

          <!-- Top Holdings -->
          {etf.holdingsJson && etf.holdingsJson.length > 0 && (
            <div>
              <h2 class="text-xl font-bold text-slate-900">Top Holdings</h2>
              <p class="mt-1 text-xs text-slate-500">As reported by fund. May not reflect real-time weights.</p>
              <div class="mt-4 overflow-hidden rounded-xl border border-slate-100 bg-white shadow-sm">
                <table class="min-w-full divide-y divide-slate-100 text-sm">
                  <thead>
                    <tr class="bg-slate-50 text-xs font-semibold uppercase text-slate-500">
                      <th class="px-4 py-3 text-left">#</th>
                      <th class="px-4 py-3 text-left">Holding</th>
                      <th class="px-4 py-3 text-right">Weight</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-slate-100">
                    {etf.holdingsJson.map((h, i) => (
                      <tr class="hover:bg-slate-50/60">
                        <td class="px-4 py-2.5 text-xs tabular-nums text-slate-400">{i + 1}</td>
                        <td class="px-4 py-2.5">
                          {h.ticker ? (
                            <span class="font-semibold text-slate-900">{h.ticker}</span>
                          ) : null}
                          {h.name && h.name !== h.ticker ? (
                            <span class="ml-2 text-slate-500">{h.name}</span>
                          ) : null}
                        </td>
                        <td class="px-4 py-2.5 text-right tabular-nums font-medium text-slate-900">
                          {h.weightPercentage > 0 ? `${h.weightPercentage.toFixed(2)}%` : '-'}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          )}

          <!-- Sector Allocation -->
          {etf.sectorWeightsJson && etf.sectorWeightsJson.length > 0 && (
            <div>
              <h2 class="text-xl font-bold text-slate-900">Sector Allocation</h2>
              <p class="mt-1 text-xs text-slate-500">Approximate sector weights as reported by fund.</p>
              <div class="mt-4 space-y-2.5">
                {etf.sectorWeightsJson.map((s) => {
                  const pct = s.weightPercentage;
                  return (
                    <div>
                      <div class="flex items-center justify-between text-sm">
                        <span class="text-slate-700">{s.sector}</span>
                        <span class="tabular-nums font-medium text-slate-900">{pct > 0 ? `${pct.toFixed(1)}%` : '-'}</span>
                      </div>
                      <div class="mt-1 h-2 w-full overflow-hidden rounded-full bg-slate-100">
                        <div
                          class="h-2 rounded-full bg-blue-500"
                          style={`width: ${Math.min(pct, 100).toFixed(1)}%`}
                        />
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          )}

        </div>
      </section>
    )}

    <!-- ── Price / Total Return chart ─────────────────────────────────────── -->
    <PriceReturnChart ticker={etf.ticker} />

    <!-- ── Distribution overview ──────────────────────────────────────────── -->
    <section class="mt-14">
      <h2 class="text-xl font-bold text-slate-900">Distributions</h2>

      {dividends.length === 0 ? (
        <p class="mt-4 text-sm text-slate-500">No distribution history in the database yet.</p>
      ) : (
        <>
          <!-- Stats grid -->
          <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            <div class="rounded-xl border border-slate-100 bg-white p-4 shadow-sm">
              <p class="text-xs font-semibold uppercase text-slate-500">TTM distributions / share</p>
              <p class="mt-2 text-xl font-semibold tabular-nums">{fmtUsd(ttmSum)}</p>
              <p class="mt-1 text-xs text-slate-400">{ttmDivs.length} payments in past 12 mo</p>
            </div>
            <div class="rounded-xl border border-slate-100 bg-white p-4 shadow-sm">
              <p class="text-xs font-semibold uppercase text-slate-500">Avg recent payment</p>
              <p class="mt-2 text-xl font-semibold tabular-nums">{fmtUsd(avgPayment)}</p>
              <p class="mt-1 text-xs text-slate-400">Mean of last {recentSix.length} payments</p>
            </div>
            <div class="rounded-xl border border-slate-100 bg-white p-4 shadow-sm">
              <p class="text-xs font-semibold uppercase text-slate-500">Projected annual / share</p>
              <p class="mt-2 text-xl font-semibold tabular-nums">{fmtUsd(projectedAnnual)}</p>
              <p class="mt-1 text-xs text-slate-400">Avg × {ppy} payments / yr</p>
            </div>
            <div class="rounded-xl border border-slate-100 bg-white p-4 shadow-sm">
              <p class="text-xs font-semibold uppercase text-slate-500">Distribution trend</p>
              <div class="mt-2">
                <span class={`inline-block rounded-full px-2.5 py-0.5 text-sm font-semibold ${trendCls}`}>
                  {distTrend}
                </span>
              </div>
              <p class="mt-1 text-xs text-slate-400">{trendDetail}</p>
              <p class="mt-1 text-[10px] leading-snug text-slate-400">
                Compares trailing 12-month regular distributions year over year. Special or year-end distributions can
                cause large single-period swings and are noted where recognised.
              </p>
            </div>
          </div>

          <!-- Distribution calculator -->
          {calcYield > 0 && calcPrice > 0 && (
            <div
              class="mt-6 rounded-2xl bg-blue-950 p-6"
              id="dist-calc"
              data-yield={calcYield}
              data-price={calcPrice}
              data-freq={calcFreq}
            >
              <!-- Header -->
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div>
                  <h3 class="font-heading text-lg">Income and DRIP calculator</h3>
                  <p class="mt-0.5 text-xs" style="color: var(--section-ink-muted)">
                    Model a starting position, optional DRIP, and estimated income
                  </p>
                </div>
                <span class="shrink-0 rounded-full bg-white/15 px-3 py-1 text-sm font-semibold tabular-nums">
                  {(calcYield * 100).toFixed(2)}% TTM yield
                </span>
              </div>

              <!-- Input -->
              <div class="mt-5 grid gap-3 lg:grid-cols-2">
                <div>
                  <label for="calc-amount" class="block text-sm font-semibold" style="color: var(--section-ink-muted)">
                    Starting investment
                  </label>
                  <div class="mt-2 flex items-center gap-1 rounded-xl border border-white/20 bg-white/10 px-4 py-3 transition-colors focus-within:border-white/50 focus-within:bg-white/15">
                    <span class="text-xl font-medium" style="color: var(--section-ink-muted)">$</span>
                    <input
                      id="calc-amount"
                      type="number"
                      min="0"
                      step="100"
                      value="10000"
                      class="min-w-0 flex-1 border-0 bg-transparent text-2xl font-bold tabular-nums focus:outline-none"
                    />
                  </div>
                </div>
                <div>
                  <label for="calc-freedom-target" class="block text-sm font-semibold" style="color: var(--section-ink-muted)">
                    Monthly freedom target
                  </label>
                  <div class="mt-2 flex items-center gap-1 rounded-xl border border-white/20 bg-white/10 px-4 py-3 transition-colors focus-within:border-white/50 focus-within:bg-white/15">
                    <span class="text-xl font-medium" style="color: var(--section-ink-muted)">$</span>
                    <input
                      id="calc-freedom-target"
                      type="number"
                      min="0"
                      step="100"
                      class="min-w-0 flex-1 border-0 bg-transparent text-2xl font-bold tabular-nums focus:outline-none"
                    />
                  </div>
                </div>
              </div>
              <label class="mt-4 flex items-center gap-3 rounded-xl bg-white/10 px-4 py-3 text-base font-medium">
                <input id="calc-drip" type="checkbox" class="h-4 w-4 rounded border-white/30 bg-transparent accent-blue-400" />
                Reinvest distributions with DRIP
              </label>
              <div class="mt-4 flex flex-wrap items-center gap-3">
                <button
                  id="calc-submit"
                  type="button"
                  class="rounded-xl border border-[var(--link-hover)] bg-[var(--btn-primary-bg)] px-5 py-3 text-base font-bold text-white shadow-sm transition hover:bg-[var(--btn-primary-hover)] focus:outline-none focus:ring-2 focus:ring-[var(--link-hover)] focus:ring-offset-2 focus:ring-offset-blue-950"
                >
                  Calculate income
                </button>
                <p class="text-sm" style="color: var(--section-ink-muted)">
                  Edit the inputs, then calculate to refresh the estimates.
                </p>
              </div>

              <!-- Output chips -->
              <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
                <!-- Per payment -->
                <div class="rounded-xl bg-white/10 px-4 py-3">
                  <p class="text-sm font-semibold" style="color: var(--section-ink-muted)">
                    {calcFreq === 'weekly' ? 'per week' : calcFreq === 'quarterly' ? 'per quarter' : calcFreq === 'semi-annual' ? 'per 6 months' : 'per month'}
                  </p>
                  <p class="mt-1.5 text-2xl font-bold tabular-nums" id="calc-period">-</p>
                </div>

                <!-- Monthly avg - skip for monthly payers (same as per payment) -->
                {calcFreq !== 'monthly' && (
                  <div class="rounded-xl bg-white/10 px-4 py-3">
                    <p class="text-sm font-semibold" style="color: var(--section-ink-muted)">monthly avg</p>
                    <p class="mt-1.5 text-2xl font-bold tabular-nums" id="calc-monthly">-</p>
                  </div>
                )}

                <!-- Annual - spans full width on mobile when 3-chip layout -->
                <div class={`rounded-xl bg-white/10 px-4 py-3 ${calcFreq !== 'monthly' ? 'col-span-2 sm:col-span-1 lg:col-span-1' : ''}`}>
                  <p class="text-sm font-semibold" style="color: var(--section-ink-muted)">per year</p>
                  <p class="mt-1.5 text-2xl font-bold tabular-nums" id="calc-annual">-</p>
                </div>
                <div class="rounded-xl bg-white/10 px-4 py-3">
                  <p class="text-sm font-semibold" style="color: var(--section-ink-muted)">target covered</p>
                  <p class="mt-1.5 text-2xl font-bold tabular-nums" id="calc-coverage">-</p>
                </div>
              </div>
              <div class="mt-4 grid gap-3 lg:grid-cols-2">
                <div class="rounded-xl bg-white/10 px-4 py-3">
                  <p class="text-sm font-semibold" style="color: var(--section-ink-muted)">cashflow blocks</p>
                  <p class="mt-1.5 text-lg font-semibold" id="calc-blocks">-</p>
                </div>
                <div class="rounded-xl bg-white/10 px-4 py-3">
                  <p class="text-sm font-semibold" style="color: var(--section-ink-muted)">one-year DRIP estimate</p>
                  <p class="mt-1.5 text-lg font-semibold" id="calc-drip-summary">-</p>
                </div>
              </div>
              <p class="mt-4 text-xs leading-relaxed" style="color: var(--section-ink-muted)">
                This is a simple educational model based on current TTM yield and price. It does not forecast price
                changes, taxes, distribution cuts, or timing of each reinvestment.
              </p>
            </div>
          )}

          <!-- Bar chart -->
          <div class="mt-8">
            <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-500">Distribution history</h3>
            <DividendChart labels={chartLabels} amounts={chartAmounts} canvasId={chartId} />
          </div>

          <!-- Table -->
          <div class="mt-8 w-full overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-100 text-sm">
              <thead>
                <tr class="bg-slate-50 text-xs font-semibold uppercase text-slate-500">
                  <th class="px-4 py-3 text-left">Ex-date</th>
                  <th class="px-4 py-3 text-left">Pay date</th>
                  <th class="px-4 py-3 text-right">Amount / share</th>
                  <th class="px-4 py-3 text-right">vs prior</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100 bg-white">
                {dividends.map((d, i) => {
                  const curr = dividendAmount(d);
                  const next = dividends[i + 1];
                  const prev = next ? dividendAmount(next) : null;
                  const chg = prev && prev > 0 ? (curr - prev) / prev : null;
                  const chgCls = chg === null ? '' : chg > 0.005 ? 'text-emerald-700' : chg < -0.005 ? 'text-rose-700' : 'text-slate-400';
                  const chgStr = chg === null ? '-' : chg >= 0 ? `+${(chg * 100).toFixed(1)}%` : `${(chg * 100).toFixed(1)}%`;
                  const special = amounts.length === 0 ? false : isSpecial(curr);
                  return (
                    <tr class="hover:bg-slate-50/60">
                      <td class="px-4 py-2.5 tabular-nums text-slate-800">
                        {String(d.exDate)}
                        {special && (
                          <span class="ml-2 inline-flex rounded-full bg-amber-50 px-1.5 py-0.5 text-[10px] font-bold uppercase tracking-wide text-amber-800 ring-1 ring-inset ring-amber-600/25" title="Anomalous payment; excluded from the year-over-year trend.">special?</span>
                        )}
                      </td>
                      <td class="px-4 py-2.5 tabular-nums text-slate-500">{d.paymentDate ? String(d.paymentDate) : '-'}</td>
                      <td class="px-4 py-2.5 text-right tabular-nums font-medium text-slate-900">${curr.toFixed(4)}</td>
                      <td class={`px-4 py-2.5 text-right tabular-nums text-xs font-medium ${chgCls}`}>{chgStr}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </>
      )}
    </section>

    <!-- ── Related ETFs ────────────────────────────────────────────────────── -->
    <section class="mt-14">
      <h2 class="text-xl font-bold text-slate-900">Others in the same pillar</h2>
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        {related.length ? (
          related.map((x) => (
            <Card>
              <a class="text-lg font-semibold text-blue-800 hover:text-blue-950" href={`/etfs/${x.ticker}`}>{x.ticker}</a>
              <p class="mt-1 text-sm text-slate-600">{x.name}</p>
            </Card>
          ))
        ) : (
          <p class="text-sm text-slate-500">No sibling ETFs in this pillar yet.</p>
        )}
      </div>
    </section>

    <p class="mt-10 text-xs text-slate-500">
      Expense ratio / issuer / frequency sourced from fund disclosures. AUM is approximate market capitalisation - confirm via fund factsheets. Yield and price data via Tiingo.
    </p>

    <Disclaimer />
  </article>
</Base>

<script>
  // Income calculator
  const calc = document.getElementById('dist-calc');
  if (calc) {
    const annualYield = parseFloat(calc.dataset.yield ?? '0');
    const price       = parseFloat(calc.dataset.price ?? '0');
    const freq        = calc.dataset.freq ?? 'monthly';
    const periodsPerYear: Record<string, number> = { weekly: 52, monthly: 12, quarterly: 4, 'semi-annual': 2, annual: 1 };
    const ppy         = periodsPerYear[freq] ?? 12;

    const input       = document.getElementById('calc-amount') as HTMLInputElement | null;
    const targetInput = document.getElementById('calc-freedom-target') as HTMLInputElement | null;
    const dripInput   = document.getElementById('calc-drip') as HTMLInputElement | null;
    const submitBtn   = document.getElementById('calc-submit') as HTMLButtonElement | null;
    const periodEl    = document.getElementById('calc-period');
    const monthlyEl   = document.getElementById('calc-monthly');
    const annualEl    = document.getElementById('calc-annual');
    const coverageEl  = document.getElementById('calc-coverage');
    const blocksEl    = document.getElementById('calc-blocks');
    const dripEl      = document.getElementById('calc-drip-summary');

    const fmt = (n: number) => `$${n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;

    const update = () => {
      const inv = parseFloat(input?.value ?? '0');
      const target = parseFloat(targetInput?.value ?? '0');
      if (!Number.isFinite(inv) || inv <= 0 || annualYield <= 0) {
        if (periodEl)  periodEl.textContent  = '-';
        if (monthlyEl) monthlyEl.textContent = '-';
        if (annualEl)  annualEl.textContent  = '-';
        if (coverageEl) coverageEl.textContent = '-';
        if (blocksEl) blocksEl.textContent = '-';
        if (dripEl) dripEl.textContent = '-';
        return;
      }
      const annual = inv * annualYield;
      const reinvestedShares = price > 0 && dripInput?.checked ? annual / price : 0;
      const monthlyIncome = annual / 12;
      const coverage = target > 0 ? (monthlyIncome / target) * 100 : 0;
      if (periodEl)  periodEl.textContent  = fmt(annual / ppy);
      if (monthlyEl) monthlyEl.textContent = fmt(annual / 12);
      if (annualEl)  annualEl.textContent  = fmt(annual);
      if (coverageEl) coverageEl.textContent = target > 0 ? `${coverage.toFixed(1)}%` : '-';
      if (blocksEl) {
        const blockIncome = 10000 * annualYield;
        const blocks = inv / 10000;
        blocksEl.textContent = `${blocks.toFixed(1)} blocks at about ${fmt(blockIncome)}/yr each`;
      }
      if (dripEl) {
        dripEl.textContent = dripInput?.checked
          ? `DRIP could add about ${reinvestedShares.toFixed(2)} shares in year one`
          : 'Taking cash; no reinvested shares modeled';
      }
    };

    submitBtn?.addEventListener('click', update);
  }
</script>
