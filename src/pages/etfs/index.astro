---
import { asc, eq } from 'drizzle-orm';

import Base from '../../layouts/Base.astro';
import Disclaimer from '../../components/ui/Disclaimer.astro';
import { db } from '../../lib/db';
import { etfs } from '../../lib/db/schema';

const list = await db
  .select()
  .from(etfs)
  .where(eq(etfs.isActive, true))
  .orderBy(asc(etfs.ticker));
---

<Base
  title="ETF directory - Yield to Freedom"
  description="Browse and filter Yield to Freedom's income ETF universe by pillar, grade, payout frequency, and more."
>
  <h1 class="font-heading text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">ETF directory</h1>
  <p class="mt-2 max-w-2xl text-slate-600">
    Filter our curated income ETF universe - open any profile for full metrics and payout history. Verify all data
    externally before investing.
  </p>

  <div class="mt-8 space-y-5" id="etf-screener-root" x-data="etfScreener()" x-cloak data-etfs={JSON.stringify(list)}>

    <!-- ── Filters + view toggle ─────────────────────────────────────── -->
    <div class="flex flex-wrap items-end gap-3">
      <div class="grid flex-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <label class="text-xs font-semibold uppercase tracking-wide text-slate-500">
          Pillar
          <span class="relative mt-1 block">
            <select
              class="w-full cursor-pointer appearance-none rounded-lg border border-slate-300 bg-white px-3 py-2 pr-10 text-sm font-medium text-slate-900 shadow-sm"
              x-model="pillar"
            >
              <option value="all">All</option>
              <option value="income">Income</option>
              <option value="stability">Stability</option>
              <option value="growth">Growth</option>
              <option value="mixed">Mixed</option>
            </select>
            <svg
              class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-[var(--fg-muted)]"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.17l3.71-3.94a.75.75 0 1 1 1.08 1.04l-4.25 4.5a.75.75 0 0 1-1.08 0l-4.25-4.5a.75.75 0 0 1 .02-1.06Z"
                clip-rule="evenodd"
              />
            </svg>
          </span>
        </label>
        <label class="text-xs font-semibold uppercase tracking-wide text-slate-500">
          Grade
          <span class="relative mt-1 block">
            <select
              class="w-full cursor-pointer appearance-none rounded-lg border border-slate-300 bg-white px-3 py-2 pr-10 text-sm font-medium text-slate-900 shadow-sm"
              x-model="grade"
            >
              <option value="all">All</option>
              <option value="A">A</option>
              <option value="B">B</option>
              <option value="C">C</option>
              <option value="D">D</option>
              <option value="__none">No grade yet</option>
            </select>
            <svg
              class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-[var(--fg-muted)]"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.17l3.71-3.94a.75.75 0 1 1 1.08 1.04l-4.25 4.5a.75.75 0 0 1-1.08 0l-4.25-4.5a.75.75 0 0 1 .02-1.06Z"
                clip-rule="evenodd"
              />
            </svg>
          </span>
        </label>
        <label class="text-xs font-semibold uppercase tracking-wide text-slate-500">
          Frequency
          <span class="relative mt-1 block">
            <select
              class="w-full cursor-pointer appearance-none rounded-lg border border-slate-300 bg-white px-3 py-2 pr-10 text-sm font-medium text-slate-900 shadow-sm"
              x-model="frequency"
            >
              <option value="all">All</option>
              <option value="monthly">Monthly</option>
              <option value="quarterly">Quarterly</option>
              <option value="annual">Annual</option>
              <option value="irregular">Irregular</option>
              <option value="__none">Unknown</option>
            </select>
            <svg
              class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-[var(--fg-muted)]"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.17l3.71-3.94a.75.75 0 1 1 1.08 1.04l-4.25 4.5a.75.75 0 0 1-1.08 0l-4.25-4.5a.75.75 0 0 1 .02-1.06Z"
                clip-rule="evenodd"
              />
            </svg>
          </span>
        </label>
        <label class="text-xs font-semibold uppercase tracking-wide text-slate-500">
          Search
          <input
            type="search"
            class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-medium text-slate-900 shadow-sm"
            placeholder="Ticker or name…"
            x-model="search"
          />
        </label>
      </div>

      <!-- View toggle -->
      <div class="flex shrink-0 overflow-hidden rounded-lg border border-slate-300 shadow-sm">
        <button
          class="flex items-center gap-1.5 px-3 py-2 text-sm font-semibold transition-colors"
          :class="view === 'cards' ? 'bg-blue-600 text-white' : 'bg-white text-slate-600 hover:bg-slate-50'"
          @click="view = 'cards'"
          title="Card view"
        >
          <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="7" height="7" rx="1" stroke="currentColor" fill="none"/>
            <rect x="14" y="3" width="7" height="7" rx="1" stroke="currentColor" fill="none"/>
            <rect x="3" y="14" width="7" height="7" rx="1" stroke="currentColor" fill="none"/>
            <rect x="14" y="14" width="7" height="7" rx="1" stroke="currentColor" fill="none"/>
          </svg>
          Cards
        </button>
        <button
          class="flex items-center gap-1.5 border-l border-slate-300 px-3 py-2 text-sm font-semibold transition-colors"
          :class="view === 'list' ? 'bg-blue-600 text-white' : 'bg-white text-slate-600 hover:bg-slate-50'"
          @click="view = 'list'"
          title="List view"
        >
          <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/>
            <line x1="8" y1="18" x2="21" y2="18"/>
            <circle cx="3" cy="6" r="1" fill="currentColor" stroke="none"/>
            <circle cx="3" cy="12" r="1" fill="currentColor" stroke="none"/>
            <circle cx="3" cy="18" r="1" fill="currentColor" stroke="none"/>
          </svg>
          List
        </button>
      </div>
    </div>

    <!-- ── Sort (cards view only) ─────────────────────────────────────── -->
    <div x-show="view === 'cards'" class="flex flex-wrap items-center gap-2 text-xs text-slate-500">
      <span class="font-semibold uppercase tracking-wide">Sort:</span>
      <template x-for="opt in cardSortOptions" :key="opt.key">
        <button
          class="rounded-full border px-3 py-1 font-medium transition-colors"
          :class="sort === opt.key ? 'border-blue-600 bg-blue-600 text-white' : 'border-slate-300 bg-white text-slate-600 hover:border-blue-400 hover:text-blue-700'"
          @click="toggleSort(opt.key)"
          x-text="opt.label + (sort === opt.key ? (dir === 'asc' ? ' ▲' : ' ▼') : '')"
        ></button>
      </template>
    </div>

    <!-- ════════════════════════════════════════════════════════════════ -->
    <!-- CARD VIEW                                                        -->
    <!-- ════════════════════════════════════════════════════════════════ -->
    <div
      x-show="view === 'cards'"
      class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
    >
      <template x-for="row in ordered" :key="row.id">
        <a
          :href="`/etfs/${row.ticker}`"
          class="group flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md"
        >
          <!-- Card header: pillar colour stripe -->
          <div class="h-1.5 w-full" :class="pillarAccent(row.pillar)"></div>

          <div class="flex flex-1 flex-col p-5">
            <!-- Ticker + grade row -->
            <div class="flex items-start justify-between gap-2">
              <span
                class="font-heading text-4xl font-extrabold leading-none tracking-tight text-blue-900 group-hover:text-blue-700"
                x-text="row.ticker"
              ></span>
              <span x-html="gradeHTML(row.ytfGrade)" class="mt-0.5 shrink-0"></span>
            </div>

            <!-- Name -->
            <p class="mt-1.5 line-clamp-2 text-xs font-medium leading-snug text-slate-600" x-text="row.name"></p>

            <!-- Pillar + category badges -->
            <div class="mt-2 flex flex-wrap gap-1.5">
              <span x-html="pillarHTML(row.pillar)"></span>
              <span x-show="row.category" x-html="categoryHTML(row.category)"></span>
            </div>

            <!-- Divider -->
            <div class="my-4 border-t border-slate-100"></div>

            <!-- Yield - hero stat -->
            <div class="flex items-end justify-between">
              <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">T12M Yield</p>
                <p
                  class="font-heading text-3xl font-extrabold tabular-nums leading-none"
                  :class="yieldColor(row.trailing12mYield)"
                  x-text="fmtYieldPct(row.trailing12mYield)"
                ></p>
              </div>
              <div class="text-right">
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Price</p>
                <p class="text-lg font-bold tabular-nums text-slate-800" x-text="fmtPrice(row.lastPrice)"></p>
              </div>
            </div>

            <!-- Stat grid -->
            <div class="mt-4 grid grid-cols-2 gap-x-4 gap-y-3">
              <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Exp. Ratio</p>
                <p class="text-sm font-bold tabular-nums text-slate-800" x-text="fmtErPct(row.expenseRatio)"></p>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Frequency</p>
                <p class="truncate text-sm font-bold capitalize text-slate-800" x-text="row.dividendFrequency ?? '-'"></p>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">AUM</p>
                <p class="text-sm font-bold tabular-nums text-slate-800" x-text="fmtAum(row.aum)"></p>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">YTF Score</p>
                <p class="text-sm font-bold tabular-nums text-slate-800" x-text="row.ytfScore ? Number(row.ytfScore).toFixed(1) : '-'"></p>
              </div>
            </div>

            <!-- Returns row (if any data) -->
            <div
              class="mt-3 grid grid-cols-3 gap-1 rounded-lg bg-slate-50 px-3 py-2"
              x-show="row.return1y || row.return3y || row.return5y"
            >
              <div class="text-center">
                <p class="text-[10px] font-semibold uppercase tracking-wide text-slate-400">1Y</p>
                <p class="text-xs font-bold tabular-nums" :class="returnColor(row.return1y)" x-text="fmtReturnPct(row.return1y)"></p>
              </div>
              <div class="border-x border-slate-200 text-center">
                <p class="text-[10px] font-semibold uppercase tracking-wide text-slate-400">3Y</p>
                <p class="text-xs font-bold tabular-nums" :class="returnColor(row.return3y)" x-text="fmtReturnPct(row.return3y)"></p>
              </div>
              <div class="text-center">
                <p class="text-[10px] font-semibold uppercase tracking-wide text-slate-400">5Y</p>
                <p class="text-xs font-bold tabular-nums" :class="returnColor(row.return5y)" x-text="fmtReturnPct(row.return5y)"></p>
              </div>
            </div>

            <!-- Footer badges: DRIP / synthetic -->
            <div class="mt-3 flex flex-wrap gap-1.5">
              <span
                x-show="row.dripEligible"
                class="inline-flex items-center rounded-full bg-emerald-50 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-emerald-800 ring-1 ring-inset ring-emerald-600/25"
              >DRIP</span>
              <span
                x-show="row.incomeSynthetic"
                class="inline-flex items-center rounded-full bg-violet-50 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-violet-800 ring-1 ring-inset ring-violet-600/25"
              >Synthetic</span>
            </div>
          </div>

          <!-- Card footer CTA -->
          <div class="border-t border-slate-100 bg-slate-50 px-5 py-2.5">
            <span class="text-xs font-semibold text-blue-700 group-hover:text-blue-900">View full profile →</span>
          </div>
        </a>
      </template>
    </div>

    <!-- ════════════════════════════════════════════════════════════════ -->
    <!-- LIST VIEW                                                        -->
    <!-- ════════════════════════════════════════════════════════════════ -->
    <div x-show="view === 'list'" class="-mx-4 overflow-x-auto sm:mx-0">
      <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
        <thead class="sticky top-0 z-10 bg-slate-50 text-xs font-semibold uppercase tracking-wide text-slate-500">
          <tr>
            <th class="cursor-pointer whitespace-nowrap px-4 py-3 hover:text-blue-700" @click="toggleSort('ticker')">
              Ticker <span x-text="caret('ticker')"></span>
            </th>
            <th class="min-w-[12rem] cursor-pointer px-4 py-3 hover:text-blue-700" @click="toggleSort('name')">
              Name <span x-text="caret('name')"></span>
            </th>
            <th class="cursor-pointer px-4 py-3 hover:text-blue-700" @click="toggleSort('pillar')">
              Pillar <span x-text="caret('pillar')"></span>
            </th>
            <th class="cursor-pointer px-4 py-3 hover:text-blue-700" @click="toggleSort('ytf_grade')">
              Grade <span x-text="caret('ytf_grade')"></span>
            </th>
            <th class="cursor-pointer whitespace-nowrap px-4 py-3 hover:text-blue-700" @click="toggleSort('trailing_yield')">
              T12M Yield <span x-text="caret('trailing_yield')"></span>
            </th>
            <th class="cursor-pointer whitespace-nowrap px-4 py-3 hover:text-blue-700" @click="toggleSort('expense')">
              Exp. Ratio <span x-text="caret('expense')"></span>
            </th>
            <th class="cursor-pointer whitespace-nowrap px-4 py-3 hover:text-blue-700" @click="toggleSort('price')">
              Price <span x-text="caret('price')"></span>
            </th>
            <th class="cursor-pointer whitespace-nowrap px-4 py-3 hover:text-blue-700" @click="toggleSort('aum')">
              AUM <span x-text="caret('aum')"></span>
            </th>
            <th class="hidden px-4 py-3 sm:table-cell">Frequency</th>
            <th class="hidden px-4 py-3 lg:table-cell">DRIP</th>
            <th class="hidden cursor-pointer whitespace-nowrap px-4 py-3 hover:text-blue-700 xl:table-cell" @click="toggleSort('return1y')">
              1Y Ret. <span x-text="caret('return1y')"></span>
            </th>
            <th class="hidden cursor-pointer whitespace-nowrap px-4 py-3 hover:text-blue-700 xl:table-cell" @click="toggleSort('ytf_score')">
              Score <span x-text="caret('ytf_score')"></span>
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 bg-white">
          <template x-for="row in ordered" :key="row.id">
            <tr class="hover:bg-blue-50/40">
              <td class="px-4 py-3 font-semibold text-blue-900">
                <a
                  class="font-heading text-base font-extrabold underline decoration-blue-700/40 hover:decoration-blue-900"
                  :href="`/etfs/${row.ticker}`"
                  x-text="row.ticker"
                ></a>
              </td>
              <td class="px-4 py-3 text-slate-700">
                <a class="hover:text-blue-800" :href="`/etfs/${row.ticker}`" x-text="row.name"></a>
              </td>
              <td class="px-4 py-3" x-html="pillarHTML(row.pillar)"></td>
              <td class="px-4 py-3" x-html="gradeHTML(row.ytfGrade)"></td>
              <td class="px-4 py-3 tabular-nums font-semibold" :class="yieldColor(row.trailing12mYield)" x-text="fmtYieldPct(row.trailing12mYield)"></td>
              <td class="px-4 py-3 tabular-nums text-slate-700" x-text="fmtErPct(row.expenseRatio)"></td>
              <td class="px-4 py-3 tabular-nums text-slate-700" x-text="fmtPrice(row.lastPrice)"></td>
              <td class="px-4 py-3 tabular-nums text-slate-700" x-text="fmtAum(row.aum)"></td>
              <td class="hidden px-4 py-3 text-xs capitalize text-slate-600 sm:table-cell">
                <span x-text="row.dividendFrequency ?? '-'"></span>
              </td>
              <td class="hidden px-4 py-3 lg:table-cell">
                <span
                  x-show="row.dripEligible"
                  class="inline-flex rounded-full bg-emerald-50 px-2 py-0.5 text-[10px] font-bold uppercase ring-1 ring-inset ring-emerald-600/25 text-emerald-800"
                >Yes</span>
                <span x-show="!row.dripEligible" class="text-xs text-slate-400">-</span>
              </td>
              <td class="hidden px-4 py-3 tabular-nums xl:table-cell" :class="returnColor(row.return1y)" x-text="fmtReturnPct(row.return1y)"></td>
              <td class="hidden px-4 py-3 tabular-nums text-slate-700 xl:table-cell" x-text="row.ytfScore ? Number(row.ytfScore).toFixed(1) : '-'"></td>
            </tr>
          </template>
        </tbody>
      </table>
    </div>

    <!-- ── Result count ───────────────────────────────────────────────── -->
    <p class="text-sm text-slate-500">
      <span x-text="ordered.length"></span> ETF<span x-text="ordered.length === 1 ? '' : 's'"></span> match filters.
    </p>
  </div>

  <noscript class="mt-10 block rounded-xl border border-amber-400 bg-amber-50 px-4 py-3 text-sm text-amber-900">
    Enable JavaScript for filtering - JSON feed:<code class="ml-2 rounded bg-white px-1 text-xs ring-1 ring-amber-400/70">/api/etfs</code>
  </noscript>

  <Disclaimer />
</Base>

<script>
  import Alpine from 'alpinejs';

  const root = document.getElementById('etf-screener-root');
  const initialRows = JSON.parse(root?.dataset.etfs ?? '[]');

  function pctFromDecimal(s: unknown): number | null {
    if (s === null || s === undefined || s === '') return null;
    const n = Number(s);
    return Number.isFinite(n) ? n * 100 : null;
  }

  function pillarAccent(pillar: unknown): string {
    const map: Record<string, string> = {
      income: 'bg-orange-400',
      stability: 'bg-indigo-400',
      growth: 'bg-teal-400',
      mixed: 'bg-slate-400',
    };
    return map[String(pillar ?? '')] ?? map['mixed']!;
  }

  function pillarHTML(pillar: unknown): string {
    const p = String(pillar ?? '');
    const map: Record<string, string> = {
      income: 'bg-orange-50 text-orange-900 ring-orange-700/25',
      stability: 'bg-indigo-50 text-indigo-900 ring-indigo-700/25',
      growth: 'bg-teal-50 text-teal-900 ring-teal-700/25',
      mixed: 'bg-slate-50 text-slate-800 ring-slate-700/25',
    };
    const cls = map[p] ?? map['mixed']!;
    return `<span class="inline-flex rounded-full px-2.5 py-0.5 text-xs font-semibold capitalize ring-1 ring-inset ${cls}">${p}</span>`;
  }

  function categoryHTML(category: unknown): string {
    const c = String(category ?? '').trim();
    if (!c) return '';
    return `<span class="inline-flex rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium text-slate-600 ring-1 ring-inset ring-slate-700/15">${c}</span>`;
  }

  function gradeHTML(grade: unknown): string {
    const g = String(grade ?? '').trim().toUpperCase();
    if (!g) return '<span class="text-xs font-medium text-slate-400">-</span>';
    const tiers: Record<string, string> = {
      A: 'bg-emerald-100 text-emerald-900 ring-emerald-600/30',
      B: 'bg-sky-100 text-sky-900 ring-sky-600/25',
      C: 'bg-amber-100 text-amber-900 ring-amber-600/25',
      D: 'bg-rose-100 text-rose-900 ring-rose-600/30',
    };
    const cls = tiers[g] ?? 'bg-slate-100 text-slate-700 ring-slate-500/25';
    return `<span class="inline-flex min-h-7 min-w-7 items-center justify-center rounded-md px-2 py-0.5 text-xs font-bold ring-1 ring-inset tabular-nums ${cls}" title="YTF grade - research purposes only.">${g}</span>`;
  }

  function yieldColor(v: unknown): string {
    const p = pctFromDecimal(v);
    if (p == null) return 'text-slate-400';
    if (p >= 10) return 'text-emerald-700';
    if (p >= 5) return 'text-blue-700';
    return 'text-slate-700';
  }

  function returnColor(v: unknown): string {
    const n = v == null || v === '' ? null : Number(v);
    if (n == null || !Number.isFinite(n)) return 'text-slate-400';
    return n >= 0 ? 'text-emerald-700' : 'text-rose-600';
  }

  interface EtfRow {
    id: number;
    ticker: string;
    name: string;
    pillar: string;
    category: string | null;
    ytfGrade: string | null;
    ytfScore: string | null;
    dividendFrequency: string | null;
    trailing12mYield: string | null;
    expenseRatio: string | null;
    lastPrice: string | null;
    aum: string | null;
    dripEligible: boolean;
    incomeSynthetic: boolean;
    return1y: string | null;
    return3y: string | null;
    return5y: string | null;
  }

  document.addEventListener('alpine:init', () => {
    Alpine.data('etfScreener', () => ({
      rows: (initialRows as EtfRow[]).map((r) => ({
        id: r.id,
        ticker: r.ticker,
        name: r.name,
        pillar: r.pillar,
        category: r.category ?? null,
        ytfGrade: r.ytfGrade ?? null,
        ytfScore: r.ytfScore ?? null,
        dividendFrequency: r.dividendFrequency ?? null,
        trailing12mYield: r.trailing12mYield ?? null,
        expenseRatio: r.expenseRatio ?? null,
        lastPrice: r.lastPrice ?? null,
        aum: r.aum ?? null,
        dripEligible: Boolean(r.dripEligible),
        incomeSynthetic: Boolean(r.incomeSynthetic),
        return1y: r.return1y ?? null,
        return3y: r.return3y ?? null,
        return5y: r.return5y ?? null,
      })),

      view: 'cards' as 'cards' | 'list',
      pillar: 'all',
      grade: 'all',
      frequency: 'all',
      search: '',
      sort: 'ticker',
      dir: 'asc' as 'asc' | 'desc',

      cardSortOptions: [
        { key: 'ticker', label: 'Ticker' },
        { key: 'trailing_yield', label: 'Yield' },
        { key: 'aum', label: 'AUM' },
        { key: 'expense', label: 'Exp. Ratio' },
        { key: 'ytf_grade', label: 'Grade' },
        { key: 'ytf_score', label: 'Score' },
      ],

      pillarAccent,
      pillarHTML,
      categoryHTML,
      gradeHTML,
      yieldColor,
      returnColor,

      fmtYieldPct(v: unknown) {
        const p = pctFromDecimal(v);
        return p == null ? '-' : `${p.toFixed(2)}%`;
      },
      fmtErPct(v: unknown) {
        const p = pctFromDecimal(v);
        return p == null ? '-' : `${p.toFixed(3)}%`;
      },
      fmtPrice(v: unknown) {
        if (v == null || v === '') return '-';
        const n = Number(v);
        return Number.isFinite(n) ? `$${n.toFixed(2)}` : '-';
      },
      fmtAum(v: unknown) {
        if (v == null || v === '') return '-';
        const n = Number(v);
        if (!Number.isFinite(n) || n === 0) return '-';
        if (n >= 1e12) return `$${(n / 1e12).toFixed(2)}T`;
        if (n >= 1e9) return `$${(n / 1e9).toFixed(2)}B`;
        if (n >= 1e6) return `$${(n / 1e6).toFixed(1)}M`;
        return `$${n.toLocaleString()}`;
      },
      fmtReturnPct(v: unknown) {
        if (v == null || v === '') return '-';
        const n = Number(v);
        if (!Number.isFinite(n)) return '-';
        const p = n * 100;
        return (p >= 0 ? '+' : '') + p.toFixed(1) + '%';
      },

      matches(row: EtfRow) {
        if (this.pillar !== 'all' && row.pillar !== this.pillar) return false;

        const g = (row.ytfGrade ?? '').trim().toUpperCase();
        if (this.grade === '__none') {
          if (g) return false;
        } else if (this.grade !== 'all' && g !== this.grade) return false;

        const f = (row.dividendFrequency ?? '').toLowerCase();
        if (this.frequency === '__none') {
          if (row.dividendFrequency) return false;
        } else if (this.frequency !== 'all' && f !== this.frequency) return false;

        const q = this.search.trim().toUpperCase();
        if (q) {
          if (!row.ticker.toUpperCase().includes(q) && !row.name.toUpperCase().includes(q)) return false;
        }

        return true;
      },

      get filtered() {
        return this.rows.filter((row: EtfRow) => this.matches(row));
      },

      get ordered() {
        const rows = [...this.filtered];
        const sign = this.dir === 'asc' ? 1 : -1;

        rows.sort((a, b) => {
          switch (this.sort) {
            case 'ticker':
              return a.ticker.localeCompare(b.ticker) * sign;
            case 'name':
              return a.name.localeCompare(b.name) * sign;
            case 'pillar':
              return a.pillar.localeCompare(b.pillar) * sign;
            case 'ytf_grade':
              return (a.ytfGrade ?? 'Z').localeCompare(b.ytfGrade ?? 'Z') * sign;
            case 'ytf_score': {
              const na = a.ytfScore != null ? Number(a.ytfScore) : -Infinity;
              const nb = b.ytfScore != null ? Number(b.ytfScore) : -Infinity;
              return na === nb ? 0 : na < nb ? -1 * sign : 1 * sign;
            }
            case 'trailing_yield': {
              const na = pctFromDecimal(a.trailing12mYield) ?? -Infinity;
              const nb = pctFromDecimal(b.trailing12mYield) ?? -Infinity;
              return na === nb ? 0 : na < nb ? -1 * sign : 1 * sign;
            }
            case 'expense': {
              const na = pctFromDecimal(a.expenseRatio) ?? Infinity;
              const nb = pctFromDecimal(b.expenseRatio) ?? Infinity;
              return na === nb ? 0 : na < nb ? -1 * sign : 1 * sign;
            }
            case 'price': {
              const na = a.lastPrice != null ? Number(a.lastPrice) : -Infinity;
              const nb = b.lastPrice != null ? Number(b.lastPrice) : -Infinity;
              return na === nb ? 0 : na < nb ? -1 * sign : 1 * sign;
            }
            case 'aum': {
              const na = a.aum != null ? Number(a.aum) : -Infinity;
              const nb = b.aum != null ? Number(b.aum) : -Infinity;
              return na === nb ? 0 : na < nb ? -1 * sign : 1 * sign;
            }
            case 'return1y': {
              const na = a.return1y != null ? Number(a.return1y) : -Infinity;
              const nb = b.return1y != null ? Number(b.return1y) : -Infinity;
              return na === nb ? 0 : na < nb ? -1 * sign : 1 * sign;
            }
            default:
              return 0;
          }
        });

        return rows;
      },

      toggleSort(key: string) {
        if (this.sort === key) {
          this.dir = this.dir === 'asc' ? 'desc' : 'asc';
        } else {
          this.sort = key;
          this.dir =
            key === 'ticker' || key === 'name' || key === 'pillar' || key === 'ytf_grade'
              ? 'asc'
              : 'desc';
        }
      },

      caret(key: string) {
        return this.sort === key ? (this.dir === 'asc' ? '▲' : '▼') : '';
      },
    }));
  });

  Alpine.start();
</script>
