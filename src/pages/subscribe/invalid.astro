---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Link invalid — Yield to Freedom"
  description="That confirmation link has expired or was already used."
>
  <section class="mx-auto max-w-xl py-16">
    <h1 class="text-3xl font-bold text-slate-900">This link is not valid</h1>
    <p class="mt-4 text-lg text-slate-600">
      The confirmation link may have expired, already been used, or was copied incorrectly. Request a fresh link
      from the homepage form.
    </p>
    <a class="mt-8 inline-flex text-sm font-semibold text-blue-700 hover:text-blue-900" href="/">Back home →</a>
  </section>
</Base>
