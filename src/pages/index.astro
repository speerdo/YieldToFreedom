---
import Base from '../layouts/Base.astro';
import GradeChip from '../components/ui/GradeChip.astro';
import { db } from '../lib/db';
import { etfs } from '../lib/db/schema';
import { publicSiteOrigin } from '../lib/site/url';
import { and, desc, eq } from 'drizzle-orm';

const site = publicSiteOrigin();

const homeSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      name: 'Yield to Freedom',
      url: site,
      description: 'Income ETF research, strategy explainers, and educational tools.',
    },
    {
      '@type': 'Organization',
      name: 'Creative Bandit LLC',
      url: site,
    },
  ],
};

type PillarKey = 'income' | 'stability' | 'growth';

async function spotlightForPillar(pillar: PillarKey) {
  const rows = await db
    .select()
    .from(etfs)
    .where(and(eq(etfs.isActive, true), eq(etfs.pillar, pillar)))
    .orderBy(desc(etfs.ytfScore))
    .limit(16);
  return rows.find((r) => r.ytfGrade === 'A') ?? rows[0] ?? null;
}

const spotIncome = await spotlightForPillar('income');
const spotStability = await spotlightForPillar('stability');
const spotGrowth = await spotlightForPillar('growth');

const spotlight = [
  { pillar: 'income' as const, row: spotIncome },
  { pillar: 'stability' as const, row: spotStability },
  { pillar: 'growth' as const, row: spotGrowth },
];

const pillarCopy = [
  {
    key: 'income' as PillarKey,
    title: 'Income',
    blurb:
      'Prioritize distributable cash flow — covered-call premiums, BDC-style payouts, and other sleeves engineered to pay you while you stay invested.',
    examples: [
      { ticker: 'JEPI', href: '/etfs/JEPI' },
      { ticker: 'JEPQ', href: '/etfs/JEPQ' },
      { ticker: 'QYLD', href: '/etfs/QYLD' },
    ],
    image: 'https://images.unsplash.com/photo-1579621970563-ebec7560ff3e?auto=format&fit=crop&w=800&q=80',
    imageAlt: 'Stacked coins representing passive dividend income',
    color: 'blue' as const,
    allocation: '40%',
  },
  {
    key: 'stability' as PillarKey,
    title: 'Stability',
    blurb:
      'Dividend growers and quality screens that aim to compound through cycles with less drama than pure high-yield chasing.',
    examples: [
      { ticker: 'SCHD', href: '/etfs/SCHD' },
      { ticker: 'VIG', href: '/etfs/VIG' },
      { ticker: 'DGRO', href: '/etfs/DGRO' },
    ],
    image: 'https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=800&q=80',
    imageAlt: 'Serene mountain lake reflecting stability and permanence',
    color: 'violet' as const,
    allocation: '30%',
  },
  {
    key: 'growth' as PillarKey,
    title: 'Growth',
    blurb:
      'Core beta and thematic exposure that can still throw off some yield while keeping equity growth in the portfolio.',
    examples: [
      { ticker: 'VOO', href: '/etfs/VOO' },
      { ticker: 'QQQ', href: '/etfs/QQQ' },
      { ticker: 'VGT', href: '/etfs/VGT' },
    ],
    image: 'https://images.unsplash.com/photo-1466692476868-aef1dfb1e735?auto=format&fit=crop&w=800&q=80',
    imageAlt: 'Lush green terraced landscape representing compound growth',
    color: 'emerald' as const,
    allocation: '30%',
  },
];

const colorMap = {
  blue: {
    badge: 'bg-blue-100 text-blue-800',
    border: 'border-blue-100',
    chip: 'bg-blue-600/10 text-blue-800 hover:bg-blue-600/20',
  },
  violet: {
    badge: 'bg-violet-100 text-violet-800',
    border: 'border-violet-100',
    chip: 'bg-violet-600/10 text-violet-800 hover:bg-violet-600/20',
  },
  emerald: {
    badge: 'bg-emerald-100 text-emerald-800',
    border: 'border-emerald-100',
    chip: 'bg-emerald-600/10 text-emerald-800 hover:bg-emerald-600/20',
  },
};

function fmtPct(s: string | null | undefined, digits = 2) {
  if (s === null || s === undefined || s === '') return '—';
  const n = Number(s);
  return Number.isFinite(n) ? `${(n * 100).toFixed(digits)}%` : '—';
}
---

<Base
  title="Yield to Freedom — Income ETF Research"
  description="Income-first ETF research mapped to Yield to Freedom pillars — Income, Stability, and Growth — plus starter guides for long-term builders."
  schema={homeSchema}
  fullWidth
>
  <!-- ── HERO ──────────────────────────────────────────────────────────── -->
  <section class="relative flex min-h-[600px] items-center overflow-hidden sm:min-h-[700px]">
    <div class="absolute inset-0 z-0">
      <img
        src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=1920&q=80"
        alt=""
        aria-hidden="true"
        class="h-full w-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-slate-950/95 via-slate-900/80 to-slate-900/30"></div>
    </div>
    <div class="relative z-10 mx-auto w-full max-w-6xl px-6 py-20 sm:py-28">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-400">Creative Bandit LLC</p>
        <h1 class="font-heading mt-4 text-balance text-5xl font-extrabold tracking-tight text-white sm:text-6xl lg:text-7xl">
          Build Income.<br class="hidden sm:block" /> Reach Freedom.
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-slate-200/90">
          Practical research for investors who want dividends and option income to do more of the heavy lifting —
          not day-trading narratives.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a
            href="/etfs"
            class="inline-flex items-center rounded-xl bg-blue-600 px-7 py-3.5 text-sm font-semibold text-white shadow-lg shadow-blue-900/40 transition-colors hover:bg-blue-500"
          >
            Explore ETFs →
          </a>
          <a
            href="/strategy"
            class="inline-flex items-center rounded-xl border border-white/25 bg-white/10 px-7 py-3.5 text-sm font-semibold text-white backdrop-blur-sm transition-colors hover:bg-white/20"
          >
            Read the playbook
          </a>
          <a
            href="/blog"
            class="inline-flex items-center rounded-xl border border-white/25 bg-white/10 px-7 py-3.5 text-sm font-semibold text-white backdrop-blur-sm transition-colors hover:bg-white/20"
          >
            Blog
          </a>
        </div>
        <p class="mt-6 text-xs text-slate-400">Educational content only — not financial advice.</p>
      </div>
    </div>
  </section>

  <!-- ── STATS STRIP ───────────────────────────────────────────────────── -->
  <div class="bg-blue-950 text-white">
    <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-center divide-x divide-white/10 px-6 py-5">
      <div class="flex flex-col items-center px-8 py-3 text-center">
        <span class="font-heading text-2xl font-bold">100+</span>
        <span class="mt-0.5 text-xs font-medium uppercase tracking-wide text-blue-300">ETFs graded</span>
      </div>
      <div class="flex flex-col items-center px-8 py-3 text-center">
        <span class="font-heading text-2xl font-bold">3</span>
        <span class="mt-0.5 text-xs font-medium uppercase tracking-wide text-blue-300">Income pillars</span>
      </div>
      <div class="flex flex-col items-center px-8 py-3 text-center">
        <span class="font-heading text-2xl font-bold">Weekly</span>
        <span class="mt-0.5 text-xs font-medium uppercase tracking-wide text-blue-300">Data syncs</span>
      </div>
      <div class="flex flex-col items-center px-8 py-3 text-center">
        <span class="font-heading text-2xl font-bold">Free</span>
        <span class="mt-0.5 text-xs font-medium uppercase tracking-wide text-blue-300">To explore</span>
      </div>
    </div>
  </div>

  <!-- ── THREE PILLARS ─────────────────────────────────────────────────── -->
  <section class="mx-auto max-w-6xl px-6 py-20 sm:py-24">
    <div class="text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.15em] text-blue-700">The framework</p>
      <h2 class="font-heading mt-3 text-3xl font-bold text-slate-900 sm:text-4xl">Three pillars (40 / 30 / 30)</h2>
      <p class="mx-auto mt-4 max-w-2xl text-slate-600">
        Every ETF profile is tagged to a pillar so you can balance <strong>cash flow</strong>,{' '}
        <strong>compounding quality</strong>, and <strong>growth</strong> without guessing which bucket a fund
        belongs in.
      </p>
    </div>

    <div class="mt-14 grid gap-8 md:grid-cols-3">
      {
        pillarCopy.map((col) => {
          const c = colorMap[col.color];
          return (
            <div
              class={`group overflow-hidden rounded-2xl border bg-white shadow-sm transition-all duration-300 hover:shadow-lg ${c.border}`}
            >
              <div class="relative aspect-[16/9] overflow-hidden">
                <img
                  src={col.image}
                  alt={col.imageAlt}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent" />
                <div class="absolute bottom-3 left-3">
                  <span class={`inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold ${c.badge}`}>
                    {col.allocation} of portfolio
                  </span>
                </div>
              </div>
              <div class="p-6">
                <h3 class="font-heading text-lg font-bold text-slate-900">{col.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-slate-600">{col.blurb}</p>
                <p class="mt-4 text-xs font-semibold uppercase tracking-wide text-slate-400">Examples</p>
                <ul class="mt-2 flex flex-wrap gap-2">
                  {col.examples.map((x) => (
                    <li>
                      <a
                        href={x.href}
                        class={`rounded-full px-3 py-1 text-xs font-semibold transition-colors ${c.chip}`}
                      >
                        {x.ticker}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          );
        })
      }
    </div>
  </section>

  <!-- ── ETF SPOTLIGHT ─────────────────────────────────────────────────── -->
  <section class="bg-slate-50 py-20 sm:py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.15em] text-blue-700">Live data</p>
        <h2 class="font-heading mt-3 text-3xl font-bold text-slate-900 sm:text-4xl">Top-rated ETFs by pillar</h2>
        <p class="mx-auto mt-4 max-w-2xl text-slate-600">
          Highest Yield to Freedom score in each pillar right now — scores refresh after each weekly data sync. Yield and
          expense figures are{' '}
          <strong class="font-semibold text-slate-700">data as of each ETF’s last vendor sync</strong>
          {' '}(see the profile for the date).
        </p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {
          spotlight.map(({ pillar, row }) => (
            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">{pillar}</p>
              {row ? (
                <>
                  <div class="mt-2 flex items-center gap-3">
                    <a
                      class="font-heading text-2xl font-bold text-blue-900 hover:underline"
                      href={`/etfs/${row.ticker}`}
                    >
                      {row.ticker}
                    </a>
                    <GradeChip grade={row.ytfGrade} />
                  </div>
                  <p class="mt-2 line-clamp-2 text-sm text-slate-600">{row.name}</p>
                  <dl class="mt-4 space-y-1.5 text-sm">
                    <div class="flex justify-between gap-4 border-b border-slate-100 pb-1.5">
                      <dt class="text-slate-500">T12M yield</dt>
                      <dd class="font-semibold tabular-nums text-slate-900">{fmtPct(row.trailing12mYield)}</dd>
                    </div>
                    <div class="flex justify-between gap-4">
                      <dt class="text-slate-500">Expense ratio*</dt>
                      <dd class="font-semibold tabular-nums text-slate-900">{fmtPct(row.expenseRatio, 3)}</dd>
                    </div>
                  </dl>
                  <a
                    class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-blue-700 transition-colors hover:text-blue-900"
                    href={`/etfs/${row.ticker}`}
                  >
                    Open profile <span aria-hidden="true">→</span>
                  </a>
                </>
              ) : (
                <p class="mt-4 text-sm text-slate-500">No active ticker in this pillar yet.</p>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── NEWSLETTER CTA ────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden bg-gradient-to-br from-blue-950 via-blue-900 to-indigo-950 py-20 sm:py-24">
    <div
      class="pointer-events-none absolute -right-24 -top-24 h-80 w-80 rounded-full bg-blue-700/20 blur-3xl"
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none absolute -bottom-16 -left-16 h-64 w-64 rounded-full bg-indigo-700/20 blur-3xl"
      aria-hidden="true"
    >
    </div>
    <div class="relative mx-auto max-w-2xl px-6 text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.15em] text-blue-300">Free resource</p>
      <h2 class="font-heading mt-3 text-3xl font-bold text-white sm:text-4xl">
        Get the Income ETF Starter Guide
      </h2>
      <p class="mt-4 text-slate-300">
        Double opt-in: we'll email a confirmation link. No spam — just the guide and occasional product updates.
      </p>
      <form id="home-subscribe" class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-stretch">
        <label class="sr-only" for="home-email">Email</label>
        <input
          id="home-email"
          name="email"
          type="email"
          required
          autocomplete="email"
          placeholder="you@example.com"
          class="min-w-0 flex-1 rounded-xl border border-white/20 bg-white/10 px-5 py-3.5 text-sm text-white placeholder:text-white/50 shadow-sm backdrop-blur-sm focus:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-400/30"
        />
        <button
          type="submit"
          class="rounded-xl bg-blue-500 px-6 py-3.5 text-sm font-semibold text-white shadow-lg transition-colors hover:bg-blue-400 disabled:opacity-50"
        >
          Request guide
        </button>
      </form>
      <p id="home-subscribe-msg" class="mt-4 hidden text-sm" aria-live="polite"></p>
      <p class="mt-4 text-xs text-slate-400">
        By subscribing you agree we may email you; you can unsubscribe later. This is not financial advice.
      </p>
    </div>
  </section>
</Base>

<script>
  const form = document.getElementById('home-subscribe');
  const msg = document.getElementById('home-subscribe-msg');
  if (form instanceof HTMLFormElement && msg) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      msg.classList.remove('hidden', 'text-red-400', 'text-emerald-400');
      msg.textContent = 'Sending…';
      msg.classList.add('text-slate-300');
      const fd = new FormData(form);
      const email = fd.get('email');
      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source: 'homepage' }),
        });
        const data = (await res.json()) as {
          ok?: boolean;
          error?: string;
          alreadyConfirmed?: boolean;
          emailSent?: boolean;
        };
        if (!res.ok) {
          msg.classList.remove('text-slate-300');
          msg.classList.add('text-red-400');
          msg.textContent =
            data.error === 'invalid_email'
              ? 'Please enter a valid email address.'
              : 'Something went wrong. Try again.';
          return;
        }
        msg.classList.remove('text-slate-300');
        msg.classList.add('text-emerald-400');
        if (data.alreadyConfirmed) {
          msg.textContent = "You're already subscribed — thanks for sticking with us.";
        } else if (data.emailSent) {
          msg.textContent = 'Check your inbox for a confirmation link to finish subscribing.';
        } else {
          msg.textContent =
            "You're on the list (dev mode): add RESEND_API_KEY to send real confirmation emails.";
        }
        form.reset();
      } catch {
        msg.classList.remove('text-slate-300');
        msg.classList.add('text-red-400');
        msg.textContent = 'Network error. Try again.';
      }
    });
  }
</script>
