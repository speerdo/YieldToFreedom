---
import Base from '../layouts/Base.astro';
import Card from '../components/ui/Card.astro';
import GradeChip from '../components/ui/GradeChip.astro';
import { db } from '../lib/db';
import { etfs } from '../lib/db/schema';
import { publicSiteOrigin } from '../lib/site/url';
import { and, desc, eq } from 'drizzle-orm';

const site = publicSiteOrigin();

const homeSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      name: 'Yield to Freedom',
      url: site,
      description: 'Income ETF research, strategy explainers, and educational tools.',
    },
    {
      '@type': 'Organization',
      name: 'Creative Bandit LLC',
      url: site,
    },
  ],
};

type PillarKey = 'income' | 'stability' | 'growth';

async function spotlightForPillar(pillar: PillarKey) {
  const rows = await db
    .select()
    .from(etfs)
    .where(and(eq(etfs.isActive, true), eq(etfs.pillar, pillar)))
    .orderBy(desc(etfs.ytfScore))
    .limit(16);
  return rows.find((r) => r.ytfGrade === 'A') ?? rows[0] ?? null;
}

const spotIncome = await spotlightForPillar('income');
const spotStability = await spotlightForPillar('stability');
const spotGrowth = await spotlightForPillar('growth');

const spotlight = [
  { pillar: 'income' as const, row: spotIncome },
  { pillar: 'stability' as const, row: spotStability },
  { pillar: 'growth' as const, row: spotGrowth },
];

const pillarCopy: {
  key: PillarKey;
  title: string;
  blurb: string;
  examples: { ticker: string; href: string }[];
}[] = [
  {
    key: 'income',
    title: 'Income',
    blurb:
      'Prioritize distributable cash flow — covered-call premiums, BDC-style payouts, and other sleeves engineered to pay you while you stay invested.',
    examples: [
      { ticker: 'JEPI', href: '/etfs/JEPI' },
      { ticker: 'JEPQ', href: '/etfs/JEPQ' },
      { ticker: 'QYLD', href: '/etfs/QYLD' },
    ],
  },
  {
    key: 'stability',
    title: 'Stability',
    blurb:
      'Dividend growers and quality screens that aim to compound through cycles with less drama than pure high-yield chasing.',
    examples: [
      { ticker: 'SCHD', href: '/etfs/SCHD' },
      { ticker: 'VIG', href: '/etfs/VIG' },
      { ticker: 'DGRO', href: '/etfs/DGRO' },
    ],
  },
  {
    key: 'growth',
    title: 'Growth',
    blurb:
      'Core beta and thematic exposure that can still throw off some yield while keeping equity growth in the portfolio.',
    examples: [
      { ticker: 'VOO', href: '/etfs/VOO' },
      { ticker: 'QQQ', href: '/etfs/QQQ' },
      { ticker: 'VGT', href: '/etfs/VGT' },
    ],
  },
];

function fmtPct(s: string | null | undefined, digits = 2) {
  if (s === null || s === undefined || s === '') return '—';
  const n = Number(s);
  return Number.isFinite(n) ? `${(n * 100).toFixed(digits)}%` : '—';
}
---

<Base
  title="Yield to Freedom — Income ETF Research"
  description="Income-first ETF research mapped to Yield to Freedom pillars — Income, Stability, and Growth — plus starter guides for long-term builders."
  schema={homeSchema}
>
  <section class="mx-auto max-w-3xl py-12 text-center sm:py-16">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-700">Creative Bandit LLC</p>
    <h1 class="mt-6 text-balance text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
      Build Income. Reach Freedom.
    </h1>
    <p class="mt-6 text-lg leading-relaxed text-slate-600">
      Practical research for investors who want dividends and option income to do more of the heavy lifting — not
      day-trading narratives. Everything here is educational, not individualized advice.
    </p>
    <div class="mt-10 flex flex-wrap justify-center gap-4">
      <a
        href="/etfs"
        class="inline-flex items-center rounded-lg bg-blue-700 px-5 py-2.5 text-sm font-semibold text-white hover:bg-blue-800"
      >
        Explore ETFs
      </a>
      <a
        href="/strategy"
        class="inline-flex items-center rounded-lg border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-slate-800 hover:bg-slate-50"
      >
        Read the playbook
      </a>
    </div>
  </section>

  <section class="mt-8 border-y border-slate-100 bg-slate-50/60 py-16">
    <h2 class="text-center text-2xl font-bold text-slate-900">Three pillars (40 / 30 / 30)</h2>
    <p class="mx-auto mt-3 max-w-2xl text-center text-slate-600">
      We tag every profile to a pillar so you can balance <strong>cash flow</strong>,{' '}
      <strong>compounding quality</strong>, and <strong>growth</strong> without guessing which bucket a fund belongs
      in.
    </p>
    <div class="mt-12 grid gap-8 md:grid-cols-3">
      {
        pillarCopy.map((col) => (
          <Card>
            <h3 class="text-lg font-bold capitalize text-blue-950">{col.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">{col.blurb}</p>
            <p class="mt-4 text-xs font-semibold uppercase text-slate-500">Examples</p>
            <ul class="mt-2 flex flex-wrap gap-2">
              {col.examples.map((x) => (
                <li>
                  <a
                    href={x.href}
                    class="rounded-full bg-blue-600/10 px-3 py-1 text-xs font-semibold text-blue-800 hover:bg-blue-600/15"
                  >
                    {x.ticker}
                  </a>
                </li>
              ))}
            </ul>
          </Card>
        ))
      }
    </div>
  </section>

  <section class="py-16">
    <div class="text-center">
      <h2 class="text-2xl font-bold text-slate-900">Top-rated ETFs (by pillar)</h2>
      <p class="mx-auto mt-3 max-w-2xl text-slate-600">
        Highest Yield to Freedom score in each pillar right now — scores refresh when we run the grader after syncing
        data.
      </p>
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {
        spotlight.map(({ pillar, row }) => (
          <Card>
            <p class="text-xs font-semibold uppercase text-slate-500">{pillar}</p>
            {row ? (
              <>
                <div class="mt-2 flex items-center gap-3">
                  <a class="text-2xl font-bold text-blue-900 hover:underline" href={`/etfs/${row.ticker}`}>
                    {row.ticker}
                  </a>
                  <GradeChip grade={row.ytfGrade} />
                </div>
                <p class="mt-2 line-clamp-2 text-sm text-slate-600">{row.name}</p>
                <dl class="mt-4 space-y-1 text-sm">
                  <div class="flex justify-between gap-4">
                    <dt class="text-slate-500">T12M yield*</dt>
                    <dd class="font-medium tabular-nums text-slate-900">{fmtPct(row.trailing12mYield)}</dd>
                  </div>
                  <div class="flex justify-between gap-4">
                    <dt class="text-slate-500">Expense*</dt>
                    <dd class="font-medium tabular-nums text-slate-900">{fmtPct(row.expenseRatio, 3)}</dd>
                  </div>
                </dl>
                <a class="mt-4 inline-block text-sm font-semibold text-blue-700 hover:text-blue-900" href={`/etfs/${row.ticker}`}>
                  Open profile →
                </a>
              </>
            ) : (
              <p class="mt-4 text-sm text-slate-500">No active ticker in this pillar yet.</p>
            )}
          </Card>
        ))
      }
    </div>
  </section>

  <section class="rounded-2xl border border-blue-100 bg-gradient-to-br from-blue-50 to-white px-6 py-12 sm:px-10">
    <div class="mx-auto max-w-xl text-center">
      <h2 class="text-2xl font-bold text-slate-900">Get the free Income ETF Starter Guide</h2>
      <p class="mt-3 text-slate-600">
        Double opt-in: we’ll email a confirmation link. No spam — just the guide and occasional product updates.
      </p>
      <form id="home-subscribe" class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-stretch">
        <label class="sr-only" for="home-email">Email</label>
        <input
          id="home-email"
          name="email"
          type="email"
          required
          autocomplete="email"
          placeholder="you@example.com"
          class="min-w-0 flex-1 rounded-lg border border-slate-300 px-4 py-3 text-sm text-slate-900 shadow-sm focus:border-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-600/20"
        />
        <button
          type="submit"
          class="rounded-lg bg-blue-700 px-5 py-3 text-sm font-semibold text-white hover:bg-blue-800 disabled:opacity-50"
        >
          Request guide
        </button>
      </form>
      <p id="home-subscribe-msg" class="mt-4 hidden text-sm" aria-live="polite"></p>
      <p class="mt-4 text-xs text-slate-500">
        By subscribing you agree we may email you; you can unsubscribe later. This is not financial advice.
      </p>
    </div>
  </section>
</Base>

<script>
  const form = document.getElementById('home-subscribe');
  const msg = document.getElementById('home-subscribe-msg');
  if (form instanceof HTMLFormElement && msg) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      msg.classList.remove('hidden', 'text-red-600', 'text-emerald-700');
      msg.textContent = 'Sending…';
      msg.classList.add('text-slate-600');
      const fd = new FormData(form);
      const email = fd.get('email');
      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source: 'homepage' }),
        });
        const data = (await res.json()) as { ok?: boolean; error?: string; alreadyConfirmed?: boolean; emailSent?: boolean };
        if (!res.ok) {
          msg.classList.remove('text-slate-600');
          msg.classList.add('text-red-600');
          msg.textContent =
            data.error === 'invalid_email' ? 'Please enter a valid email address.' : 'Something went wrong. Try again.';
          return;
        }
        msg.classList.remove('text-slate-600');
        msg.classList.add('text-emerald-700');
        if (data.alreadyConfirmed) {
          msg.textContent = 'You’re already subscribed — thanks for sticking with us.';
        } else if (data.emailSent) {
          msg.textContent = 'Check your inbox for a confirmation link to finish subscribing.';
        } else {
          msg.textContent =
            'You’re on the list (dev mode): add RESEND_API_KEY to send real confirmation emails from this machine.';
        }
        form.reset();
      } catch {
        msg.classList.remove('text-slate-600');
        msg.classList.add('text-red-600');
        msg.textContent = 'Network error. Try again.';
      }
    });
  }
</script>
