---
interface Props {
  title: string;
  description: string;
  schema?: object;
  ogImage?: string;
  ogType?: 'website' | 'article';
}
const { title, description, schema, ogImage, ogType = 'website' } = Astro.props;
const siteBase = Astro.site ?? new URL(Astro.url.origin);
const canonical = new URL(Astro.url.pathname, siteBase);
const defaultOgImage = new URL('/og-default.png', siteBase).toString();
const ogImageUrl = ogImage
  ? (ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteBase).toString())
  : defaultOgImage;
---
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical.toString()} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical.toString()} />
<meta property="og:type" content={ogType} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content="Yield to Freedom" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

{schema ? (
  <script type="application/ld+json" is:inline>{JSON.stringify(schema)}</script>
) : null}
