---
import ThemeToggle from './ThemeToggle.astro';
import Logo from './Logo.astro';

const themes = [
  { id: 'light',  label: 'Light',  bg: '#e2e8f0' },
  { id: 'dark',   label: 'Dark',   bg: '#0f172a' },
  { id: 'tan',    label: 'Tan',    bg: '#f2e0c4' },
  { id: 'purple', label: 'Purple', bg: '#1a0830' },
];
---

<header class="border-b border-[var(--border)] bg-[var(--bg)]">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-4">

    <!-- Logo -->
    <Logo />

    <!-- Desktop nav (hidden on mobile) -->
    <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-[var(--fg-muted)]">
      <a href="/etfs"      class="hover:text-[var(--fg)]">ETFs</a>
      <a href="/compare"   class="hover:text-[var(--fg)]">Compare</a>
      <a href="/blog"      class="hover:text-[var(--fg)]">Blog</a>
      <a href="/strategy"  class="hover:text-[var(--fg)]">Strategy</a>
      <a href="/about"     class="hover:text-[var(--fg)]">About</a>
      <ThemeToggle />
    </nav>

    <!-- Mobile: hamburger only (theme lives inside the drawer) -->
    <button
      id="mobile-menu-btn"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="flex h-10 w-10 items-center justify-center rounded-md text-[var(--fg-muted)] hover:text-[var(--fg)] md:hidden"
    >
      <svg id="icon-hamburger" width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <line x1="3" y1="6"  x2="19" y2="6"  stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <line x1="3" y1="11" x2="19" y2="11" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <line x1="3" y1="16" x2="19" y2="16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <svg id="icon-close" width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true" class="hidden">
        <line x1="5" y1="5"  x2="17" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <line x1="17" y1="5" x2="5"  y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div id="mobile-menu" class="hidden border-t border-[var(--border)] bg-[var(--bg)] md:hidden">
    <div class="mx-auto max-w-6xl px-4">

      <!-- Theme picker — inline, no popover, large touch targets -->
      <div class="border-b border-[var(--border)] py-4">
        <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-[var(--fg-muted)]">Theme</p>
        <div class="flex gap-5">
          {themes.map(t => (
            <button
              data-mobile-theme={t.id}
              aria-label={`${t.label} theme`}
              aria-pressed="false"
              class="mobile-theme-btn flex flex-col items-center gap-1.5"
            >
              <span class="mobile-theme-dot" style={`background:${t.bg};`}></span>
              <span class="mobile-theme-label text-[10px] font-semibold uppercase tracking-wide text-[var(--fg-muted)]">
                {t.label}
              </span>
            </button>
          ))}
        </div>
      </div>

      <!-- Nav links -->
      <nav class="flex flex-col text-base font-medium text-[var(--fg-muted)]">
        <a href="/etfs"      class="border-b border-[var(--border)] py-3 hover:text-[var(--fg)]">ETFs</a>
        <a href="/compare"   class="border-b border-[var(--border)] py-3 hover:text-[var(--fg)]">Compare</a>
        <a href="/blog"      class="border-b border-[var(--border)] py-3 hover:text-[var(--fg)]">Blog</a>
        <a href="/strategy"  class="border-b border-[var(--border)] py-3 hover:text-[var(--fg)]">Strategy</a>
        <a href="/about"     class="py-3 hover:text-[var(--fg)]">About</a>
      </nav>
    </div>
  </div>
</header>

<style>
  .mobile-theme-dot {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 2px solid color-mix(in srgb, var(--fg) 15%, transparent);
    display: block;
    transition: transform 0.12s;
  }

  .mobile-theme-btn[aria-pressed="true"] .mobile-theme-dot {
    border-color: transparent;
    box-shadow: 0 0 0 2.5px var(--bg), 0 0 0 5px var(--fg);
    transform: scale(1.08);
  }

  .mobile-theme-btn[aria-pressed="true"] .mobile-theme-label {
    color: var(--fg);
  }
</style>

<script is:inline>
  (function () {
    var btn   = document.getElementById('mobile-menu-btn');
    var menu  = document.getElementById('mobile-menu');
    var iconH = document.getElementById('icon-hamburger');
    var iconX = document.getElementById('icon-close');

    function syncMobileTheme() {
      var current = document.documentElement.getAttribute('data-theme') || 'light';
      document.querySelectorAll('.mobile-theme-btn').forEach(function (s) {
        s.setAttribute('aria-pressed', s.getAttribute('data-mobile-theme') === current ? 'true' : 'false');
      });
    }

    function openMenu() {
      menu.classList.remove('hidden');
      iconH.classList.add('hidden');
      iconX.classList.remove('hidden');
      btn.setAttribute('aria-expanded', 'true');
      syncMobileTheme(); // read current theme each time menu opens
    }

    function closeMenu() {
      menu.classList.add('hidden');
      iconH.classList.remove('hidden');
      iconX.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
    }

    btn.addEventListener('click', function () {
      menu.classList.contains('hidden') ? openMenu() : closeMenu();
    });

    // Close drawer when a nav link is tapped
    menu.querySelectorAll('a').forEach(function (link) {
      link.addEventListener('click', closeMenu);
    });

    // Mobile theme swatches
    document.querySelectorAll('.mobile-theme-btn').forEach(function (swatch) {
      swatch.addEventListener('click', function () {
        var id = swatch.getAttribute('data-mobile-theme');
        document.documentElement.setAttribute('data-theme', id);
        localStorage.setItem('ytf-theme', id);
        syncMobileTheme();
        // Keep desktop popover swatches in sync
        document.querySelectorAll('.theme-swatch').forEach(function (s) {
          s.setAttribute('aria-pressed', s.getAttribute('data-theme-id') === id ? 'true' : 'false');
        });
        closeMenu();
      });
    });
  })();
</script>
