---
import ThemeToggle from './ThemeToggle.astro';
---
<header class="border-b border-[var(--border)] bg-[var(--bg)]">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-4 py-4">
    <a href="/" class="font-heading flex items-center gap-2 font-bold tracking-tight text-[var(--fg)]">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <circle cx="10" cy="10" r="9" fill="currentColor" opacity="0.12"/>
        <path d="M10 14V7M7 10l3-3 3 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Yield to Freedom
    </a>
    <nav class="flex flex-wrap items-center gap-6 text-sm font-medium text-[var(--fg-muted)]">
      <a href="/etfs"         class="hover:text-[var(--fg)]">ETFs</a>
      <a href="/compare"      class="hover:text-[var(--fg)]">Compare</a>
      <a href="/blog"         class="hover:text-[var(--fg)]">Blog</a>
      <a href="/strategy"     class="hover:text-[var(--fg)]">Strategy</a>
      <a href="/about"        class="hover:text-[var(--fg)]">About</a>
      <ThemeToggle />
    </nav>
  </div>
</header>
